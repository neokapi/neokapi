{
  "manifest_version": "1",
  "plugin": "check",
  "version": "0.1.0",
  "description": "kapi-check ML checker — runs a small, open, multilingual sentence-embedding ONNX model in-process and speaks a line-delimited JSON protocol on stdin/stdout. Backs the voice/style-similarity and register checks; the deterministic checks need no model.",
  "homepage": "https://github.com/neokapi/neokapi/tree/main/plugins/check",
  "author": "Neokapi <hello@neokapi.dev>",
  "license": "Apache-2.0",
  "binary": "kapi-check",
  "min_kapi_version": "0.0.1",
  "group": "neokapi",
  "capabilities": {
    "selfcheck": true
  },
  "models": [
    {
      "id": "e5-small-int8",
      "version": "1",
      "default": true,
      "description": "multilingual-e5-small, int8 ONNX sentence-embedding model (dim 384). Pinned to intfloat commit 614241f.",
      "license": "MIT",
      "files": [
        {
          "path": "model.onnx",
          "url": "https://huggingface.co/intfloat/multilingual-e5-small/resolve/614241f622f53c4eeff9890bdc4f31cfecc418b3/onnx/model_qint8_avx512_vnni.onnx",
          "sha256": "dd476dd0c2514e9b9be83aeb3853fac0763e0bdf4a71645407587d77c48a2d88",
          "size": 118346824
        },
        {
          "path": "tokenizer.json",
          "url": "https://huggingface.co/intfloat/multilingual-e5-small/resolve/614241f622f53c4eeff9890bdc4f31cfecc418b3/tokenizer.json",
          "sha256": "0b44a9d7b51c3c62626640cda0e2c2f70fdacdc25bbbd68038369d14ebdf4c39",
          "size": 17082730
        }
      ]
    }
  ],
  "metadata": {
    "check": {
      "protocol": "checkproto-line-json-v1",
      "transport": "stdin-stdout",
      "invocation": ["kapi-check", "serve"],
      "acquire": ["kapi", "models", "pull", "check"],
      "protocol_package": "github.com/neokapi/neokapi/plugins/check/checkproto",
      "ops": ["embed", "similarity", "ping", "info"],
      "models": [
        {
          "name": "e5-small-int8",
          "default": true,
          "source": "intfloat/multilingual-e5-small",
          "onnx_file": "onnx/model_qint8_avx512_vnni.onnx",
          "tokenizer": "intfloat/multilingual-e5-small",
          "dim": 384,
          "download_mb": 129,
          "license": "MIT"
        }
      ]
    }
  }
}
