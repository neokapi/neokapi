{
  "manifest_version": "1",
  "plugin": "pdfium",
  "version": "0.1.0",
  "description": "PDFium-backed PDF reader — extracts correct text (incl. CID/CJK) and per-segment geometry from PDFs via Google's PDFium. Runs as an isolated daemon so a malformed PDF can't crash kapi.",
  "homepage": "https://github.com/neokapi/neokapi/tree/main/plugins/pdfium",
  "author": "Neokapi <hello@neokapi.dev>",
  "license": "Apache-2.0",
  "binary": "kapi-pdfium",
  "min_kapi_version": "0.0.1",
  "group": "neokapi",
  "capabilities": {
    "selfcheck": true,
    "formats": [
      {
        "name": "pdf",
        "display_name": "PDF (PDFium)",
        "description": "Text + geometry extraction via PDFium.",
        "extensions": [".pdf"],
        "mime_types": ["application/pdf"],
        "capabilities": ["read"],
        "schema": "formats/pdf/schema.json"
      }
    ]
  },
  "daemon": {
    "handshake": { "type": "stdio-handshake", "fields": ["socket", "version"] }
  }
}
