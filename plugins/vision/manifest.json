{
  "manifest_version": "1",
  "plugin": "vision",
  "version": "0.1.0",
  "description": "Document vision for kapi — OCR + ML layout detection (PP-DocLayoutV3; table structure in a later phase) over page images via PP-OCRv5 mobile ONNX models, run in-process and driven over a binary-framed stdin/stdout protocol.",
  "homepage": "https://github.com/neokapi/neokapi/tree/main/plugins/vision",
  "author": "Neokapi <hello@neokapi.dev>",
  "license": "Apache-2.0",
  "binary": "kapi-vision",
  "min_kapi_version": "0.0.1",
  "group": "neokapi",
  "capabilities": {
    "selfcheck": true
  },
  "models": [
    {
      "id": "ppocrv5-mobile",
      "version": "1",
      "default": true,
      "bundled": true,
      "description": "PP-OCRv5 mobile (text detection + recognition) — bundled OCR model.",
      "license": "Apache-2.0",
      "files": [
        { "path": "ppocrv5_det.onnx" },
        { "path": "ppocrv5_rec.onnx" },
        { "path": "ppocrv5_dict.txt" }
      ]
    }
  ],
  "metadata": {
    "vision": {
      "protocol": "visionproto-framed-v1",
      "transport": "stdin-stdout",
      "invocation": ["kapi-vision", "serve"],
      "protocol_package": "github.com/neokapi/neokapi/plugins/vision/visionproto",
      "ops": ["ping", "info", "ocr", "layout"],
      "engine": "ppocrv5-mobile",
      "models": [
        { "key": "layout", "file": "ppdoclayoutv3.onnx", "role": "layout-detection", "on_demand": true },
        { "key": "det", "file": "ppocrv5_det.onnx", "role": "text-detection" },
        { "key": "rec", "file": "ppocrv5_rec.onnx", "role": "recognition", "default": true }
      ]
    }
  }
}
