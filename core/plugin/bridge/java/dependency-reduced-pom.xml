<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.gokapi</groupId>
  <artifactId>gokapi-bridge</artifactId>
  <name>gokapi-bridge</name>
  <version>1.0.0</version>
  <description>Java bridge for Okapi Framework filters, communicating via NDJSON over stdin/stdout</description>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.6.0</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <transformers>
                <transformer>
                  <mainClass>com.gokapi.bridge.OkapiBridgeServer</mainClass>
                </transformer>
              </transformers>
              <finalName>gokapi-bridge-${project.version}-jar-with-dependencies</finalName>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <repositories>
    <repository>
      <id>okapi</id>
      <name>Okapi Framework Repository</name>
      <url>https://okapiframework.org/maven2/</url>
    </repository>
  </repositories>
  <properties>
    <maven.compiler.target>11</maven.compiler.target>
    <gson.version>2.11.0</gson.version>
    <maven.compiler.source>11</maven.compiler.source>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <okapi.version>1.47.0</okapi.version>
  </properties>
</project>
