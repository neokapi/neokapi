{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://neokapi.dev/schemas/plugin-manifest/v1.json",
  "title": "Kapi plugin manifest (v1)",
  "description": "Sidecar manifest.json shipped inside every plugin directory. Declares everything the plugin provides — commands, MCP tools, format readers/writers, flow tools, source connectors, and recipe schema extensions.",
  "type": "object",
  "required": ["manifest_version", "plugin", "version", "binary"],
  "properties": {
    "manifest_version": {
      "description": "Schema version of this manifest. Currently always \"1\".",
      "type": "string",
      "enum": ["1"]
    },
    "plugin": {
      "description": "Plugin's unique name. Used as install dir name and dispatch key.",
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "version": {
      "description": "Plugin semver (e.g., \"1.4.0\").",
      "type": "string"
    },
    "description": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "author": { "type": "string" },
    "license": { "type": "string", "description": "SPDX license identifier" },
    "binary": {
      "description": "Executable path within the plugin dir. Forward slashes only; no leading slash; no `..` segments. Examples: \"kapi-bowrain\", \"bin/kapi-okapi-bridge\", \"Contents/MacOS/kapi-okapi-bridge\".",
      "type": "string",
      "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:$|/)).+$"
    },
    "min_kapi_version": { "type": "string" },
    "group": { "type": "string" },
    "models": {
      "type": "array",
      "description": "Large model/data assets the host fetches, verifies, and caches on the plugin's behalf.",
      "items": {
        "type": "object",
        "required": ["id", "version", "files"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "version": { "type": "string" },
          "default": { "type": "boolean" },
          "description": { "type": "string" },
          "license": { "type": "string" },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["path", "url", "sha256"],
              "additionalProperties": false,
              "properties": {
                "path": { "type": "string", "pattern": "^[^/\\\\]+$" },
                "url": { "type": "string", "format": "uri" },
                "sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
                "size": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "short": { "type": "string" },
              "long": { "type": "string" },
              "args": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "additionalProperties": false,
                  "properties": {
                    "name": { "type": "string" },
                    "optional": { "type": "boolean" },
                    "variadic": { "type": "boolean" }
                  }
                }
              },
              "flags": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "type"],
                  "additionalProperties": false,
                  "properties": {
                    "name": { "type": "string" },
                    "short": { "type": "string", "maxLength": 1 },
                    "type": { "type": "string", "enum": ["bool", "string", "int", "stringSlice"] },
                    "description": { "type": "string" },
                    "default": {}
                  }
                }
              },
              "subcommands": { "type": "array", "items": { "$ref": "#/$defs/subcommand" } }
            }
          }
        },
        "mcp_tools": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "formats": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "display_name": { "type": "string" },
              "description": { "type": "string" },
              "extensions": { "type": "array", "items": { "type": "string" } },
              "mime_types": { "type": "array", "items": { "type": "string" } },
              "capabilities": {
                "type": "array",
                "items": { "type": "string", "enum": ["read", "write", "generative", "interchange"] }
              },
              "schema": { "type": "string" }
            }
          }
        },
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "category": { "type": "string" },
              "inputs": { "type": "array", "items": { "type": "string" } },
              "outputs": { "type": "array", "items": { "type": "string" } },
              "schema": { "type": "string" }
            }
          }
        },
        "selfcheck": {
          "type": "boolean",
          "description": "The plugin implements the standard `<binary> doctor` self-check run by `kapi plugins doctor`."
        },
        "segmenters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "display_name": { "type": "string" },
              "description": { "type": "string" },
              "order": { "type": "integer" },
              "schema": { "type": "string" }
            }
          }
        },
        "source_connectors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "schema_extensions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "scope"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "scope": { "type": "string", "enum": ["project", "defaults", "collection", "item"] },
              "group": { "type": "string" },
              "json_schema": { "type": "string" }
            }
          }
        },
        "command_contributions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["command", "handler"],
            "additionalProperties": false,
            "properties": {
              "command": { "type": "string" },
              "handler": { "type": "string" },
              "short": { "type": "string" },
              "engage_when": { "type": "string" },
              "flags": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "type"],
                  "additionalProperties": false,
                  "properties": {
                    "name": { "type": "string" },
                    "short": { "type": "string", "maxLength": 1 },
                    "type": { "type": "string", "enum": ["bool", "string", "int", "stringSlice"] },
                    "description": { "type": "string" },
                    "default": {}
                  }
                }
              }
            }
          }
        }
      }
    },
    "daemon": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "idle_timeout_seconds": { "type": "integer", "minimum": 1 },
        "startup_timeout_seconds": { "type": "integer", "minimum": 1 },
        "handshake": {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["stdio-handshake"] },
            "fields": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  },
  "$defs": {
    "subcommand": {
      "description": "A nested subcommand. Either a bare string (a leaf, e.g. \"login\") or an object with a name and its own nested subcommands (e.g. {\"name\": \"token\", \"subcommands\": [\"create\", \"list\", \"delete\"]}).",
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "subcommands": { "type": "array", "items": { "$ref": "#/$defs/subcommand" } }
          }
        }
      ]
    }
  }
}
