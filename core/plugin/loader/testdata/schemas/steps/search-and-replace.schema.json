{
  "$id": "search-and-replace",
  "title": "Search and Replace",
  "type": "object",
  "toolMeta": {
    "id": "search-and-replace",
    "displayName": "Search and Replace",
    "description": "Performs search and replace on the entire file or the text units. Expects raw document or filter events. Sends back: raw document or filter events."
  },
  "x-step": {
    "class": "net.sf.okapi.steps.searchandreplace.SearchAndReplaceStep",
    "inputType": "filter-events",
    "outputType": "filter-events",
    "parameterMappings": ["SOURCE_LOCALE", "TARGET_LOCALE", "ROOT_DIRECTORY"]
  },
  "properties": {
    "regEx": {
      "type": "boolean",
      "default": false
    },
    "dotAll": {
      "type": "boolean",
      "default": false
    },
    "ignoreCase": {
      "type": "boolean",
      "default": false
    },
    "multiLine": {
      "type": "boolean",
      "default": false
    },
    "target": {
      "type": "boolean",
      "default": true
    },
    "source": {
      "type": "boolean",
      "default": false
    },
    "replaceALL": {
      "type": "boolean",
      "default": true
    },
    "replacementsPath": {
      "type": "string",
      "default": ""
    },
    "logPath": {
      "type": "string",
      "default": "${rootDir}/replacementsLog.txt"
    },
    "saveLog": {
      "type": "boolean",
      "default": false
    },
    "count": {
      "type": "integer",
      "default": 0
    }
  }
}
