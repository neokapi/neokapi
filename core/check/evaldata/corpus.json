{
  "_about": "Labeled eval corpus for the content checks. Each case is an input (source, optional target) plus the finding categories a correct check SHOULD produce (expect) and, where calibrated, the rolled-up compliance score it must yield (expect_score, 0-100). The check-eval harness (scripts/checkeval) runs the checks over these cases and reports precision/recall/F1 AND score calibration; a regression test gates both. expect_score pins the severity weighting (neutral 0 / minor 1 / major 5 / critical 25): a DNT or dropped-placeholder violation is critical (100-25=75), a stray extra placeholder is major (100-5=95). Seed it from the checkers' unit + adversarial cases; grow it from a real correction stream behind a privacy filter. See issues #759 and #758.",
  "cases": [
    {
      "id": "dnt-translated",
      "check": "dnt",
      "source": "Open the Acme Cloud dashboard",
      "target": "Öffnen Sie das Akme-Wolke Dashboard",
      "target_lang": "de",
      "dnt": ["Acme Cloud"],
      "expect": ["do-not-translate"],
      "expect_score": 75,
      "note": "product name translated → flag (critical)"
    },
    {
      "id": "dnt-preserved",
      "check": "dnt",
      "source": "Open the Acme Cloud dashboard",
      "target": "Öffnen Sie das Acme Cloud Dashboard",
      "target_lang": "de",
      "dnt": ["Acme Cloud"],
      "expect": [],
      "expect_score": 100,
      "note": "product name kept verbatim → no flag (true negative)"
    },
    {
      "id": "dnt-word-boundary",
      "check": "dnt",
      "source": "We are going home",
      "target": "Wir gehen nach Hause",
      "target_lang": "de",
      "dnt": ["Go"],
      "expect": [],
      "expect_score": 100,
      "note": "\"Go\" must not match inside \"going\" — false-positive guard"
    },
    {
      "id": "dnt-case-sensitive",
      "check": "dnt",
      "source": "Use iPhone now",
      "target": "Benutze Iphone jetzt",
      "target_lang": "de",
      "dnt": ["iPhone"],
      "expect": ["do-not-translate"],
      "expect_score": 75,
      "note": "case matters: iPhone → Iphone is a violation (critical)"
    },
    {
      "id": "placeholder-dropped",
      "check": "placeholder",
      "source": "You have {count} items",
      "target": "Sie haben Artikel",
      "target_lang": "de",
      "expect": ["placeholder"],
      "expect_score": 75,
      "note": "{count} dropped → flag (critical)"
    },
    {
      "id": "placeholder-preserved",
      "check": "placeholder",
      "source": "You have {count} items",
      "target": "Sie haben {count} Artikel",
      "target_lang": "de",
      "expect": [],
      "expect_score": 100,
      "note": "{count} kept → no flag"
    },
    {
      "id": "placeholder-printf-dropped",
      "check": "placeholder",
      "source": "Loaded %d items in %s",
      "target": "Elemente geladen",
      "target_lang": "de",
      "expect": ["placeholder"],
      "expect_score": 50,
      "note": "%d and %s both dropped → two critical violations (100-25-25)"
    },
    {
      "id": "placeholder-extra",
      "check": "placeholder",
      "source": "Hello {name}",
      "target": "Hallo {name} {stray}",
      "target_lang": "de",
      "expect": ["placeholder"],
      "expect_score": 95,
      "note": "unexpected {stray} in target → major (100-5)"
    },
    {
      "id": "placeholder-numbered-tag",
      "check": "placeholder",
      "source": "Click <0>here</0> to continue",
      "target": "Klicken Sie <0>hier</0>, um fortzufahren",
      "target_lang": "de",
      "expect": [],
      "expect_score": 100,
      "note": "numbered tags preserved → no flag"
    },
    {
      "id": "placeholder-none",
      "check": "placeholder",
      "source": "Just plain text",
      "target": "Nur einfacher Text",
      "target_lang": "de",
      "expect": [],
      "expect_score": 100,
      "note": "no placeholders → no flag"
    }
  ]
}
