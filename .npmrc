# pnpm registry/auth config. Behavioral pnpm settings (workspace linking,
# pre/post scripts, dependency overrides) live in pnpm-workspace.yaml — pnpm 11
# reads those from there, not from .npmrc/package.json. See https://pnpm.io/settings.

# Suppress peer-dependency warnings from Storybook's transitive deps that have
# not declared Vite 8 support yet.
loglevel=error

# @neokapi/* packages that are NOT in this workspace (none today) would resolve
# from GitHub Packages; workspace members always resolve locally first.
@neokapi:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
