# Hoist dependencies to root node_modules/ for cross-workspace dedup.
# npm 11 defaults to isolated installs which creates duplicate react copies.
install-strategy=hoisted

# Suppress peer dependency warnings from Storybook's transitive deps
# that haven't declared Vite 8 support yet.
loglevel=error

# @neokapi/react is published to GitHub Packages (workspace packages under
# @neokapi/* still resolve locally first; this only affects non-workspace deps).
@neokapi:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
