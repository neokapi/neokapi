{
  "name": "@neokapi/kapi-format",
  "version": "1.0.0",
  "private": false,
  "description": "Canonical TypeScript schema for the Kapi Localization Format (KLF). Block/Run content model, reference Level-1 preview renderer, target validator, annotation overlay resolver. Mirrors core/klf in Go byte-for-byte against shared golden fixtures.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./block": "./src/block.ts",
    "./vocabulary": "./src/vocabulary.ts",
    "./preview": "./src/preview.ts",
    "./annotation": "./src/annotation.ts",
    "./klf": "./src/klf.ts",
    "./target-plural": "./src/target-plural.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./block": {
        "types": "./dist/block.d.ts",
        "default": "./dist/block.js"
      },
      "./vocabulary": {
        "types": "./dist/vocabulary.d.ts",
        "default": "./dist/vocabulary.js"
      },
      "./preview": {
        "types": "./dist/preview.d.ts",
        "default": "./dist/preview.js"
      },
      "./annotation": {
        "types": "./dist/annotation.d.ts",
        "default": "./dist/annotation.js"
      },
      "./klf": {
        "types": "./dist/klf.d.ts",
        "default": "./dist/klf.js"
      },
      "./target-plural": {
        "types": "./dist/target-plural.d.ts",
        "default": "./dist/target-plural.js"
      },
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepack": "node build.mjs",
    "typecheck": "vp check --no-fmt --no-lint",
    "validate": "node --experimental-strip-types examples/validate.ts",
    "test": "vp test"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
