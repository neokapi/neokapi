{
  "name": "@neokapi/kapi-format",
  "version": "0.1.1",
  "private": true,
  "description": "Canonical TypeScript schema for the Kapi Localization Format (KLF). Block/Run content model, reference Level-1 preview renderer, target validator, annotation overlay resolver. Mirrors core/klf in Go byte-for-byte against shared golden fixtures.",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./block": {
      "types": "./src/block.ts",
      "node": "./dist/block.js",
      "default": "./src/block.ts"
    },
    "./vocabulary": {
      "types": "./src/vocabulary.ts",
      "node": "./dist/vocabulary.js",
      "default": "./src/vocabulary.ts"
    },
    "./preview": {
      "types": "./src/preview.ts",
      "node": "./dist/preview.js",
      "default": "./src/preview.ts"
    },
    "./annotation": {
      "types": "./src/annotation.ts",
      "node": "./dist/annotation.js",
      "default": "./src/annotation.ts"
    },
    "./klf": {
      "types": "./src/klf.ts",
      "node": "./dist/klf.js",
      "default": "./src/klf.ts"
    },
    "./target-plural": {
      "types": "./src/target-plural.ts",
      "node": "./dist/target-plural.js",
      "default": "./src/target-plural.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "vpx tsc --noEmit",
    "validate": "node --experimental-strip-types examples/validate.ts",
    "test": "vitest run"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  }
}
