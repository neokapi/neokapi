{
  "name": "@neokapi/kapi-react",
  "version": "0.1.1",
  "private": true,
  "description": "Zero-config i18n for React. Transforms vanilla JSX at build time using W3C HTML5 translatability rules. Supports build-time inlining (zero runtime) and OTA dynamic loading. Extracts translatable content as Kapi Localization Format (KLF).",
  "keywords": [
    "i18n",
    "internationalization",
    "l10n",
    "localization",
    "nextjs",
    "react",
    "translation",
    "vite",
    "webpack"
  ],
  "license": "Apache-2.0",
  "bin": {
    "kapi-react": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/plugin/index.d.ts",
      "default": "./dist/plugin/index.js"
    },
    "./vite": {
      "types": "./dist/plugin/vite.d.ts",
      "default": "./dist/plugin/vite.js"
    },
    "./webpack": {
      "types": "./dist/plugin/webpack.d.ts",
      "default": "./dist/plugin/webpack.js"
    },
    "./rollup": {
      "types": "./dist/plugin/rollup.d.ts",
      "default": "./dist/plugin/rollup.js"
    },
    "./esbuild": {
      "types": "./dist/plugin/esbuild.d.ts",
      "default": "./dist/plugin/esbuild.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./runtime/pseudo": {
      "types": "./dist/runtime/pseudo.d.ts",
      "default": "./dist/runtime/pseudo.js"
    },
    "./storybook": {
      "types": "./dist/storybook/index.d.ts",
      "default": "./dist/storybook/index.js"
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "test": "vp test",
    "test:watch": "vp test watch",
    "typecheck": "vp check --no-fmt --no-lint",
    "lint": "vp lint",
    "fmt": "vp fmt --write src/ tests/",
    "fmt:check": "vp fmt --check src/ tests/",
    "check": "vp run typecheck && vp run lint && vp run fmt:check && vp run test"
  },
  "dependencies": {
    "@neokapi/kapi-format": "*",
    "@swc/core": "^1.15.41",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-syntax-jsx": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/types": "^7.29.0",
    "@storybook/react-vite": "^10.4.3",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "esbuild": "^0.28.0",
    "react": "^19.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "@babel/core": "^7.29.7",
    "@storybook/react-vite": "^10.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "storybook": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "@babel/core": {
      "optional": true
    },
    "@storybook/react-vite": {
      "optional": true
    },
    "storybook": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
