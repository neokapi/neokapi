{
  "name": "kapi-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "build:dev": "vp build",
    "preview": "vp preview",
    "check": "vp check",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "test": "vp test",
    "test:watch": "vp test watch",
    "extract": "vpx kapi-react extract --out i18n/ --target-locale qps --src \"src/**/*.{tsx,jsx}\" --src \"../../../packages/ui/src/**/*.tsx\" --src \"../../../packages/flow-editor/src/**/*.tsx\" --ignore \"src/stories/**\" --ignore \"../../../packages/*/src/stories/**\" --ignore \"../../../packages/*/src/__tests__/**\"",
    "compile": "vpx kapi-react compile i18n-qps/ --out public/translations",
    "compile:nb": "vpx kapi-react compile i18n-nb/ --out public/translations --locale nb"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@lexical/react": "^0.46.0",
    "@neokapi/concept-ui": "*",
    "@neokapi/contract-types": "*",
    "@neokapi/flow-editor": "*",
    "@neokapi/kapi-lab": "*",
    "@neokapi/kapi-react": "*",
    "@neokapi/reference-data": "*",
    "@neokapi/ui-primitives": "*",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "@wailsio/runtime": "^3.0.0-alpha.79",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lexical": "^0.46.0",
    "lucide-react": "^1.22.0",
    "mutative": "^1.3.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.2",
    "travels": "^1.1.0",
    "use-travel": "^1.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.1"
  }
