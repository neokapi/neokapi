{
  "name": "gokapi-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "e2e:screenshots": "playwright test --config playwright.config.ts",
    "e2e:recordings": "playwright test --config playwright.recordings.config.ts",
    "e2e:tests": "playwright test --config playwright.e2e.config.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lexical/react": "^0.39.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.161.3",
    "lexical": "^0.39.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.18",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^4.0.18"
  }
}
