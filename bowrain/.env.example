# Local full-stack configuration — copy to bowrain/.env and edit.
#   cp .env.example .env
#
# compose.full.yaml auto-loads bowrain/.env. Everything here is OPTIONAL: the
# stack runs out of the box with the offline "demo" translation provider.
# Set a real provider below to get genuine machine translations on push.

# ── Translation upstream (bowrain-worker) ────────────────────────────────────
# Provider used for "platform" translation jobs (the built-in auto-translate-
# on-push automation). One of: demo | gemini | openai | anthropic | ollama
BOWRAIN_PLATFORM_PROVIDER=demo

# Default model for the platform provider. Leave empty to use the provider's
# own default (e.g. gemini-2.5-flash). For non-Azure providers this WINS over
# the per-project model, so set it to a model your provider actually serves.
#   gemini  → gemini-2.5-flash
#   openai  → gpt-4o-mini
BOWRAIN_PLATFORM_MODEL=

# API key. Either set BOWRAIN_PLATFORM_API_KEY directly, or use the provider-
# specific variable below (GEMINI_API_KEY / OPENAI_API_KEY / ANTHROPIC_API_KEY).
BOWRAIN_PLATFORM_API_KEY=

# Optional base-URL override (self-hosted endpoint / proxy / Ollama host).
BOWRAIN_PLATFORM_BASE_URL=

# Provider-specific keys (used when BOWRAIN_PLATFORM_API_KEY is unset):
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Image overrides (optional) ───────────────────────────────────────────────
# Skip building from source by pointing at prebuilt images, e.g.:
# BOWRAIN_SERVER_IMAGE=ghcr.io/neokapi/bowrain-server:latest
# BOWRAIN_WORKER_IMAGE=ghcr.io/neokapi/bowrain-worker:latest
# BOWRAIN_WEB_IMAGE=ghcr.io/neokapi/bowrain-web:latest

# Example: real Gemini translations
#   BOWRAIN_PLATFORM_PROVIDER=gemini
#   BOWRAIN_PLATFORM_MODEL=gemini-2.5-flash
#   GEMINI_API_KEY=AIza...
