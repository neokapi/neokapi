# ZeroClaw configuration for @bravo agent containers.
# Model/provider config is handled by ZEROCLAW_* env vars (not in this file).
# Only gateway + MCP settings need to be in the config file.

[gateway]
port = 42617
host = "0.0.0.0"
allow_public_bind = true
require_pairing = false

[mcp]
enabled = true
deferred_loading = false

[[mcp.servers]]
name = "bowrain"
transport = "http"
url = "${BRAVO_MCP_ENDPOINT}"
headers = { Authorization = "Bearer ${BRAVO_AGENT_TOKEN}" }
tool_timeout_secs = 120
