      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Content and flow features are disabled. Resolve by installing missing plugins or adjusting version constraints below, then save."
          }
        ],
        "nb": [
          {
            "text": "Innholds- og flytfunksjoner er deaktivert. Løs dette ved å installere manglende tillegg eller justere versjonskravene nedenfor, og lagre deretter."
          }
        ]
      },
