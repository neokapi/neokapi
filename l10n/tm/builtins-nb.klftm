    {
      "id": "builtins-nb:71c7cb4b92",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "How kapi exchanges content with external TMS and CAT tools through standard bilingual formats — extract to XLIFF or PO, translate anywhere, and merge back byte-exactly while keeping translation memory and terminology in the loop."
          }
        ],
        "nb": [
          {
            "text": "Hvordan kapi utveksler innhold med eksterne TMS- og CAT-verktøy gjennom standard tospråklige formater — trekk ut til XLIFF eller PO, oversett hvor som helst, og flett tilbake byte-eksakt med oversettelsesminne og terminologi i sløyfen."
          }
        ]
      },
      "created": "2026-06-11T13:20:28Z",
      "updated": "2026-06-11T13:20:28Z"
    },
