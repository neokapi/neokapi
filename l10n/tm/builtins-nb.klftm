      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Surface an XML comment immediately preceding an entry as a translator note on the emitted block. Comments always round-trip verbatim regardless of this setting."
          }
        ],
        "nb": [
          {
            "text": "Vis en XML-kommentar rett foran en oppføring som oversettermerknad på den utsendte blokken. Kommentarer bevares alltid uendret ved rundtur uavhengig av denne innstillingen."
          }
        ]
      },
      "origins": [
