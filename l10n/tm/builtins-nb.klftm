      "id": "builtins-nb:a9445af295",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Add target elements for monolingual XLIFF files that have no target in the source"
          }
        ],
        "nb": [
          {
            "text": "Legg til target-elementer for enspråklige XLIFF-filer som mangler target i kilden"
          }
        ]
