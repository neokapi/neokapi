    {
      "id": "builtins-nb.tmx:tu214@tmx-361ab663",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Extract $description values (human-readable token and group documentation) as translatable blocks. This is the only natural-language field in DTCG; $value is always a typed design value (colour, dimension, font name, …) and is never extracted. Disable to read the file as fully non-translatable structure."
          }
        ],
        "nb": [
          {
            "text": "Trekk ut $description-verdier (lesbar dokumentasjon for tokener og grupper) som oversettbare blokker. Dette er det eneste naturspråklige feltet i DTCG; $value er alltid en typet designverdi (farge, dimensjon, skriftnavn, …) og trekkes aldri ut. Deaktiver for å lese filen som fullstendig ikke-oversettbar struktur."
          }
        ]
      },
      "origins": [
