      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "When non-empty, only keys matching one of these glob patterns are extracted. Supports * (single key) and ** (any depth)."
          }
        ],
        "nb": [
          {
            "text": "Når ikke tom, trekkes bare nøkler som matcher ett av disse glob-mønstrene ut. Støtter * (én nøkkel) og ** (vilkårlig dybde)."
          }
        ]
      },
