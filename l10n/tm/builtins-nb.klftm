      "id": "builtins-nb.tmx:tu56@tmx-361ab663",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Automatically accept tracked changes before extraction. When true (default, matching Okapi), inserted runs are kept and deleted runs are dropped; rows marked with <w:trPr><w:del/> (ECMA-376 §17.13.5.13) are removed entirely; rows marked with <w:trPr><w:ins/> (§17.13.5.16) are kept."
          }
        ],
        "nb": [
          {
            "text": "Godta sporede endringer automatisk før uttrekk. Når true (standard, som i Okapi), beholdes innsatte runs og slettede runs forkastes; rader merket med <w:trPr><w:del/> (ECMA-376 §17.13.5.13) fjernes helt; rader merket med <w:trPr><w:ins/> (§17.13.5.16) beholdes."
          }
        ]
      },
      "origins": [
