    },
    {
      "id": "builtins-nb:a9d40583bf",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Hand values whose key ends in \"_html\" (the i18next convention for markup) to the HTML subfilter so tags are protected and text remains translatable. Off by default: the HTML subfilter is not byte-faithful for bare markup fragments."
          }
        ],
        "nb": [
          {
            "text": "Send verdier med nøkler som slutter på \"_html\" (i18next-konvensjonen for oppmerking), til HTML-underfilteret slik at tagger beskyttes og teksten forblir oversettbar. Av som standard: HTML-underfilteret er ikke byte-tro for rene oppmerkingsfragmenter."
          }
        ]
      },
      "created": "2026-06-11T08:02:58Z",
      "updated": "2026-06-11T08:02:58Z"
    },
