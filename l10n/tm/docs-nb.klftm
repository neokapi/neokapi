    {
      "id": "docs-nb.tmx:tu-241@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Five starter packs ship built in: `professional-b2b`, `friendly-dtc`, `technical-docs`, `marketing-blog`, and `customer-support`. See [Brand Voice](/framework/checks/brand-voice)."
          }
        ],
        "nb": [
          {
            "text": "Fem startpakker følger med innebygd: `professional-b2b`, `friendly-dtc`, `technical-docs`, `marketing-blog` og `customer-support`. Se [Merkevarestemme](/framework/checks/brand-voice)."
          }
        ]
      },
