            "text": "Bla i terminologi og oversettelsesminne"
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "docs-nb:8b6c7c22ff",
      "hintSrcLang": "en",
      "variants": {
