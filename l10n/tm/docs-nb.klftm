    },
    {
      "id": "docs-nb.tmx:tu-24@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "\"Interchange\" spans three distinct boundaries. They share one seam — the\nsame format readers and writers over kapi's content model — but differ in\nwho they talk to and where the durable state lives:"
          }
        ],
        "nb": [
          {
            "text": "«Utveksling» spenner over tre ulike grenser. De deler én søm — de samme\nformatleserne og -skriverne over kapis innholdsmodell — men skiller seg i hvem de\nsnakker med og hvor den varige tilstanden bor:"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-1548425fb44d29f8-1781164979411269788"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
