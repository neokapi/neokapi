      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Edit the generated `app.kapi` to declare content globs, target\nlocales, and any optional recipe sections. Then seed the project TM\nfrom existing memory, if you have any:"
          }
        ],
        "nb": [
          {
            "text": "Rediger den genererte `app.kapi` for å oppgi innholdsglobber, målspråk og\neventuelle valgfrie oppskriftsseksjoner. Fyll deretter prosjektets\noversettelsesminne fra eksisterende minne, hvis du har noe:"
          }
        ]
      },
