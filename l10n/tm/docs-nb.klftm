    {
      "id": "docs-nb.tmx:tu-39@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Edit the generated `app.kapi` to declare content globs, target locales, and any optional recipe sections. Then seed the project TM from existing memory, if you have any:"
          }
        ],
        "nb": [
          {
            "text": "Rediger den genererte `app.kapi` for å oppgi innholdsglobber, målspråk og eventuelle valgfrie oppskriftsseksjoner. Fyll deretter prosjektets oversettelsesminne fra eksisterende minne, hvis du har noe:"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T06:47:09Z",
