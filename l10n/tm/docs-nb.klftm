    {
      "id": "docs-nb.tmx:tu-4@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "**[Kapi Desktop](/kapi/desktop/overview)** — a visual companion app for\n  building flows, running tools, managing plugins, and storing AI credentials —\n  without writing YAML or remembering flags."
          }
        ],
        "nb": [
          {
            "text": "**[Kapi Desktop](/kapi/desktop/overview)** — en visuell følgeapp for å\n  bygge flyter, kjøre verktøy, håndtere tillegg og lagre AI-legitimasjon —\n  uten å skrive YAML eller huske flagg."
          }
        ]
      },
      "origins": [
        {
