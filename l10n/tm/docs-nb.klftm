      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Print a brand voice guide to paste into your AI assistant's context, starting from a built-in starter pack:"
          }
        ],
        "nb": [
          {
            "text": "Skriv ut en merkevarestemme-guide du kan lime inn i AI-assistentens kontekst, med utgangspunkt i en innebygd startpakke:"
          }
        ]
      },
      "origins": [
