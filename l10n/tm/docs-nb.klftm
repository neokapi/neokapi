      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "[Modes & bindings](/kapi/modes) — the source/sink binding model and when to mix\n  ad-hoc and project runs."
          }
        ],
        "nb": [
          {
            "text": "[Moduser og bindinger](/kapi/modes) — kilde-/sluk-bindingsmodellen og når du bør\n  kombinere ad hoc- og prosjektkjøringer."
          }
        ]
      },
      "origins": [
        {
