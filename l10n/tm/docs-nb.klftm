    },
    {
      "id": "docs-nb.tmx:tu-209@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Kapi Desktop is the visual companion to the CLI. Each package below installs the `kapi` CLI as a dependency, so a single install covers both. See the [Kapi Desktop overview](/kapi/desktop/overview) for what it does."
          }
        ],
        "nb": [
          {
            "text": "Kapi Desktop er den visuelle følgesvennen til CLI-en. Hver pakke under installerer `kapi`-CLI-en som en avhengighet, så én enkelt installasjon dekker begge. Se [Kapi Desktop-oversikten](/kapi/desktop/overview) for hva den gjør."
          }
        ]
      },
