    {
      "id": "docs-nb.tmx:tu-236@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "This needs a provider credential, so install first and add one with `kapi credentials add` — see [Installation](/kapi/get-started/installation). When a brand voice profile is bound on the flow, its guide is injected into the translation prompt, so output is on-brand at generation time."
          }
        ],
        "nb": [
          {
            "text": "Dette krever leverandørlegitimasjon, så installer først og legg til en med `kapi credentials add` — se [Installering](/kapi/get-started/installation). Når en merkevarestemme-profil er bundet til flyten, settes guiden dens inn i oversettelsesprompten, slik at utdataene følger merkevaren allerede ved generering."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
