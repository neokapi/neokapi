    },
    {
      "id": "docs-nb:bd72fbe30b",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Install plugins (optional). In Plugins, browse the registry and\n   install the Okapi Bridge to add its document formats and filters; new\n   formats appear automatically."
          }
        ],
        "nb": [
          {
            "text": "**Installer tillegg (valgfritt).** I **Plugins**, bla i registeret og\n   installer **Okapi Bridge** for å legge til dokumentformatene og filtrene\n   dens; nye formater dukker opp automatisk."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
