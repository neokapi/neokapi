      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "docs-nb:73dd496bff",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "See the project file reference for the full .kapi\nformat."
          }
        ],
        "nb": [
          {
            "text": "Se [referansen for prosjektfiler](/reference/project-file) for det\nfullstendige `.kapi`-formatet."
          }
        ]
      },
