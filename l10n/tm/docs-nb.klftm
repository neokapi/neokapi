    },
    {
      "id": "docs-nb.tmx:tu-185@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "[Interchange — XLIFF, PO, and your TMS](/kapi/bilingual-workflow) — extract a project to bilingual files for vendor or human translation, then merge back."
          }
        ],
        "nb": [
          {
