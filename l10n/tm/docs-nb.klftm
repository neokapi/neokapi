      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "[Modes & bindings](/kapi/modes) — how ad-hoc and project runs differ, and when\n  to mix them."
          }
        ],
        "nb": [
          {
            "text": "[Moduser og bindinger](/kapi/modes) — hvordan ad hoc- og prosjektkjøringer\n  skiller seg, og når du bør kombinere dem."
          }
        ]
      },
      "origins": [
