    {
      "id": "docs-nb.tmx:tu-47@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Extraction bookkeeping (the captured skeletons and a manifest) recorded\n  in the project's gitignored cache so `kapi merge` can reattach the\n  returned translations and rebuild the source byte-for-byte — for document\n  and markup formats and for keyed catalog formats alike (JSON, YAML,\n  `.properties`, Android XML, `.resx`, Apple\n  `.strings`/`.stringsdict`/`.xcstrings`, `.arb`, i18next, design tokens)"
          }
        ],
        "nb": [
          {
            "text": "Uttrekksbokføring (de fangede skjelettene og et manifest) lagret i prosjektets\n  gitignorerte hurtigbuffer slik at `kapi merge` kan feste de returnerte\n  oversettelsene igjen og gjenoppbygge kilden byte for byte — for dokument- og\n  markupformater så vel som for nøkkelbaserte katalogformater (JSON, YAML,\n  `.properties`, Android XML, `.resx`, Apple\n  `.strings`/`.stringsdict`/`.xcstrings`, `.arb`, i18next, designtokener)"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-1548425fb44d29f8-1781164979411269788"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "docs-nb.tmx:tu-48@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "A file-level `<note category=\"kapi\">` on each XLIFF stamping the\n  batch id, source file, and source hash"
          }
        ],
        "nb": [
          {
            "text": "En `<note category=\"kapi\">` på filnivå i hver XLIFF som stempler batch-id,\n  kildefil og kildehash"
          }
        ]
      },
      "origins": [
