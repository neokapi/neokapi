    {
      "id": "docs-nb.tmx:tu-209@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Kapi Desktop is the visual companion to the CLI. Each package below installs the\n`kapi` CLI as a dependency, so a single install covers both. See the\n[Kapi Desktop overview](/kapi/desktop/overview) for what it does."
          }
        ],
        "nb": [
          {
            "text": "Kapi Desktop er den visuelle følgesvennen til CLI-en. Hver pakke under\ninstallerer `kapi`-CLI-en som en avhengighet, så én enkelt installasjon dekker\nbegge. Se [Kapi Desktop-oversikten](/kapi/desktop/overview) for hva den gjør."
          }
        ]
      },
