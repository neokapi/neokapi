        "en": [
          {
            "text": "[Installation](/kapi/get-started/installation) — all platforms and options"
          }
        ],
        "nb": [
          {
            "text": "[Installering](/kapi/get-started/installation) — alle plattformer og alternativer"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T06:47:09Z",
