            "text": "[Installering](/kapi/get-started/installation) — alle plattformer og alternativer"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
