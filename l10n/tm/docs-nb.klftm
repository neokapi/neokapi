    },
    {
      "id": "docs-nb.tmx:tu-68@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "PO output carries kapi's bookkeeping as extracted comments:"
          }
        ],
        "nb": [
          {
            "text": "PO-utdata bærer kapis bokføring som uttrukne kommentarer:"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T06:47:09Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-1548425fb44d29f8-1781160429293846857"
        }
      ],
      "created": "2026-06-11T06:47:09Z",
