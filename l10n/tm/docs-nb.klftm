      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Score a draft against a profile. `--min-score` makes it a CI gate — kapi exits non-zero when the score is below the threshold:"
          }
        ],
        "nb": [
          {
            "text": "Vurder et utkast mot en profil. `--min-score` gjør det til en CI-port — kapi avslutter med ikke-null når poengsummen er under terskelen:"
          }
        ]
      },
      "origins": [
