    },
    {
      "id": "docs-nb.tmx:tu-3@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "**[Kapi CLI](/kapi/cli)** — a single binary that operates directly on files. Best for automation, scripting, CI gates, and offline work; no project or server required. It also serves brand and terminology tools to your AI assistant over [MCP](/reference/mcp)."
          }
        ],
        "nb": [
          {
            "text": "**[Kapi CLI](/kapi/cli)** — én binærfil som arbeider direkte på filer. Best for automatisering, skripting, CI-porter og frakoblet arbeid; krever verken prosjekt eller server. Den tilbyr også merkevare- og terminologiverktøy til AI-assistenten din over [MCP](/reference/mcp)."
          }
        ]
      },
      "origins": [
