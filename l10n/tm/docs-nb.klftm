    {
      "id": "docs-nb:c2d23ebf72",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "With editable, the command is placed at the prompt instead of running\nautomatically — press Enter when you're ready, or tweak it first:"
          }
        ],
        "nb": [
          {
            "text": "Med `editable` plasseres kommandoen ved ledeteksten i stedet for å kjøre\nautomatisk — trykk **Enter** når du er klar, eller juster den først:"
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
