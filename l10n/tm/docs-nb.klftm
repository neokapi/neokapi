      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Input can be a file argument, `--text \"…\"`, or piped via stdin. Rewrite off-voice content — forbidden terms, competitor mentions, jargon:"
          }
        ],
        "nb": [
          {
            "text": "Inndata kan være et filargument, `--text \"…\"`, eller sendes via stdin. Skriv om innhold som bryter med stemmen — forbudte termer, konkurrentomtaler, sjargong:"
          }
        ]
      },
