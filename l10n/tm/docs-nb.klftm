    {
      "id": "docs-nb.tmx:tu-246@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Next: set up a project"
          }
        ],
        "nb": [
          {
            "text": "Neste: sett opp et prosjekt"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-1548425fb44d29f8-1781164979411269788"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
