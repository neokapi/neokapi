      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Day 0: initialize and seed the TM"
          }
        ],
        "nb": [
          {
            "text": "Dag 0: initialiser og fyll oversettelsesminnet"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T06:47:09Z",
