    {
      "id": "docs-nb.tmx:tu-206@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "The rule-based commands — pseudo-translate, word-count, brand checks against a\nprofile file — need no credential. For LLM-backed translation, QA, and review,\nsave a provider key once under a name you'll reference in flows:"
          }
        ],
        "nb": [
          {
            "text": "De regelbaserte kommandoene — pseudooversettelse, ordtelling, merkevaresjekker\nmot en profilfil — trenger ingen legitimasjon. For LLM-basert oversettelse,\nkvalitetskontroll og gjennomgang lagrer du en leverandørnøkkel én gang under et\nnavn du refererer til i flyter:"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-1548425fb44d29f8-1781164979411269788"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "docs-nb.tmx:tu-207@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Credentials live in your OS keychain. See the\n[Quick Start](/kapi/get-started/quickstart) for what to run next."
          }
        ],
        "nb": [
          {
            "text": "Legitimasjon ligger i operativsystemets nøkkelring. Se\n[hurtigstarten](/kapi/get-started/quickstart) for hva du kan kjøre videre."
          }
        ]
      },
      "origins": [
