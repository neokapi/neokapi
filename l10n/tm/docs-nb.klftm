    },
    {
      "id": "docs-nb.tmx:tu-11@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Projects and ad-hoc"
          }
        ],
        "nb": [
          {
            "text": "Prosjekter og ad hoc"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
