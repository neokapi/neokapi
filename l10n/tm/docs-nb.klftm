    {
      "id": "docs-nb.tmx:tu-236@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "This needs a provider credential, so install first and add one with\n`kapi credentials add` — see [Installation](/kapi/get-started/installation). When a\nbrand voice profile is bound on the flow, its guide is injected into the\ntranslation prompt, so output is on-brand at generation time."
          }
        ],
        "nb": [
          {
            "text": "Dette krever leverandørlegitimasjon, så installer først og legg til en med\n`kapi credentials add` — se [Installering](/kapi/get-started/installation). Når en\nmerkevarestemme-profil er bundet til flyten, settes guiden dens inn i\noversettelsesprompten, slik at utdataene følger merkevaren allerede ved\ngenerering."
          }
        ]
      },
      "origins": [
