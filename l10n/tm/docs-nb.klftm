          {
            "text": "Kapi Project Files — Full format reference"
          }
        ],
        "nb": [
          {
            "text": "[Kapi-prosjektfiler](/reference/project-file) — full formatreferanse"
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "docs-nb:87331d6c75",
      "hintSrcLang": "en",
      "variants": {
