    },
    {
      "id": "docs-nb.tmx:tu-24@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "\"Interchange\" spans three distinct boundaries. They share one seam — the same format readers and writers over kapi's content model — but differ in who they talk to and where the durable state lives:"
          }
        ],
        "nb": [
          {
            "text": "«Utveksling» spenner over tre ulike grenser. De deler én søm — de samme formatleserne og -skriverne over kapis innholdsmodell — men skiller seg i hvem de snakker med og hvor den varige tilstanden bor:"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T06:47:09Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-1548425fb44d29f8-1781160429293846857"
        }
      ],
      "created": "2026-06-11T06:47:09Z",
      "updated": "2026-06-11T06:47:09Z"
    },
