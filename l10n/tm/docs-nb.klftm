    },
    {
      "id": "docs-nb.tmx:tu-36@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "A minimal recipe wiring extract/merge into a React app:"
          }
        ],
        "nb": [
          {
            "text": "En minimal oppskrift som kobler extract/merge inn i en React-app:"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T06:47:09Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-1548425fb44d29f8-1781160429293846857"
        }
      ],
      "created": "2026-06-11T06:47:09Z",
      "updated": "2026-06-11T06:47:09Z"
    },
    {
      "id": "docs-nb.tmx:tu-37@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "The `merge`, `tm`, and `segmentation` sections are described in detail on the [Kapi project file reference](/reference/project-file). All three are optional — defaults apply when a section is omitted."
          }
        ],
        "nb": [
          {
            "text": "Seksjonene `merge`, `tm` og `segmentation` er beskrevet i detalj i [referansen for Kapi-prosjektfiler](/reference/project-file). Alle tre er valgfrie — standardverdier gjelder når en seksjon utelates."
          }
        ]
      },
      "origins": [
