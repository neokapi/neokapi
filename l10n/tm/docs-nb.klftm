      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Next: set up a project"
          }
        ],
        "nb": [
          {
            "text": "Neste: sett opp et prosjekt"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T06:47:09Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-1548425fb44d29f8-1781160429293846857"
