    },
    {
      "id": "docs-nb.tmx:tu-208@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Install Kapi Desktop"
          }
        ],
        "nb": [
          {
            "text": "Installer Kapi Desktop"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T06:47:09Z",
