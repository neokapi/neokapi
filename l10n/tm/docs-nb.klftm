      "id": "docs-nb.tmx:tu-184@tmx-1548425f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "[Modes & bindings](/kapi/modes) — the source/sink binding model and when to mix ad-hoc and project runs."
          }
        ],
        "nb": [
          {
            "text": "[Moduser og bindinger](/kapi/modes) — kilde-/sluk-bindingsmodellen og når du bør kombinere ad hoc- og prosjektkjøringer."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "docs-nb.tmx",
          "addedAt": "2026-06-11T06:47:09Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-1548425fb44d29f8-1781160429293846857"
        }
      ],
      "created": "2026-06-11T06:47:09Z",
