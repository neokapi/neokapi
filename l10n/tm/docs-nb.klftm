    },
    {
      "id": "docs-nb:57b7f911cb",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "3. Read the recipe"
          }
        ],
        "nb": [
          {
            "text": "3. Les oppskriften"
          }
