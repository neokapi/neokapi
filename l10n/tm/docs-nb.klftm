    {
      "id": "docs-nb:51f58cf402",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "The <dir-name>.kapi recipe is a portable YAML document. A minimal one declares\nits languages, the content globs to localize, and the flows to run:"
          }
        ],
        "nb": [
          {
            "text": "`<dir-name>.kapi`-oppskriften er et portabelt YAML-dokument. En minimal en\noppgir språkene sine, innholdsglobene som skal lokaliseres, og flytene som skal\nkjøres:"
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "docs-nb:52118489c0",
      "hintSrcLang": "en",
      "variants": {
