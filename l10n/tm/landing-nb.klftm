    {
      "id": "landing-nb:1ad8658bc9",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "A single self-contained binary with SQLite-backed TM and termbase. Run local models with Ollama. Nothing leaves your machine unless you choose a cloud LLM."
          }
        ],
        "nb": [
          {
            "text": "Én selvstendig binærfil med SQLite-basert oversettelsesminne og termbase. Kjør lokale modeller med Ollama. Ingenting forlater maskinen din med mindre du velger en sky-LLM."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
