      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Extract translatable text, change it, and write the original file back — structure, markup, inline tags, and placeholders intact. `kapi extract` then `kapi merge`, unchanged except where you intended."
          }
        ],
        "nb": [
          {
            "text": "Trekk ut tekst, endre den, og skriv originalfilen tilbake — struktur, oppmerking, inline-kode og plassholdere intakt. `kapi extract`, så `kapi merge`, uendret bortsett fra der du ville endre."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
