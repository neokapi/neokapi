    {
      "id": "landing-nb.tmx:tu-82@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Native readers and writers for localization, data, content, subtitle, and office formats, detected by extension, MIME type, or content — with more available through the okapi-bridge. A round-trip, in place, not string-and-key extraction."
          }
        ],
        "nb": [
          {
            "text": "Innebygde lesere og skrivere for lokaliserings-, data-, innholds-, undertekst- og kontorformater, gjenkjent på filendelse, MIME-type eller innhold — med flere tilgjengelige gjennom okapi-bridge. En rundtur, på plass, ikke streng-og-nøkkel-uttrekk."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "landing-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
