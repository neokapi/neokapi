      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "List the supported file formats. neokapi detects formats by extension, MIME type, or content sniffing."
          }
        ],
        "nb": [
          {
            "text": "List opp filformatene som støttes. neokapi gjenkjenner formater på filendelse, MIME-type eller innhold."
          }
        ]
      },
