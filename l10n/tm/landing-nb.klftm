      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Write the result into the original native format, unchanged except where you intended — a byte-faithful round-trip, in every locale (with more formats through the okapi-bridge)."
          }
        ],
        "nb": [
          {
            "text": "Skriv resultatet inn i det opprinnelige formatet, uendret bortsett fra der du ville endre — en byte-trofast rundtur, for hver språkkode (med flere formater gjennom okapi-bridge)."
          }
        ]
      },
