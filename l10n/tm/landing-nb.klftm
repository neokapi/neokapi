    {
      "id": "landing-nb.tmx:tu-110@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Run the checks like tests: do-not-translate, placeholder and tag integrity, terminology, and brand voice. Findings are specific and actionable — the exact strings and rules that broke."
          }
        ],
        "nb": [
          {
            "text": "Kjør sjekkene som tester: ikke-oversett, plassholder- og kodeintegritet, terminologi og merkevarestemme. Funnene er konkrete og handlingsrettede — nøyaktig hvilke strenger og regler som røk."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "landing-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-88cc79a04a89cc77-1781164979720993643"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb.tmx:tu-111@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Score text 0–100 across tone, style, vocabulary, clarity, and compliance. --min-score gates CI and exits 3 below the threshold."
          }
        ],
        "nb": [
          {
            "text": "Gi tekst poeng 0–100 for tone, stil, vokabular, klarhet og etterlevelse. --min-score setter port i CI og avslutter med kode 3 under terskelen."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "landing-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-88cc79a04a89cc77-1781164979720993643"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb.tmx:tu-112@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Serve the engine — extract, translate, check, term and TM lookup — to your AI assistant over MCP."
          }
        ],
        "nb": [
          {
            "text": "Tilby motoren — uttrekk, oversettelse, sjekker, term- og TM-oppslag — til AI-assistenten din over MCP."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "landing-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-88cc79a04a89cc77-1781164979720993643"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
