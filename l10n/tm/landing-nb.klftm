      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Leverage a TMX translation memory with fuzzy matching and import a termbase (CSV/JSON/TBX) to keep preferred and forbidden terms consistent across everything you ship."
          }
        ],
        "nb": [
          {
            "text": "Gjenbruk et TMX-oversettelsesminne med fuzzy-treff, og importer en termbase (CSV/JSON/TBX) for å holde foretrukne og forbudte termer konsistente i alt du leverer."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
