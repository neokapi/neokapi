      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Verify AI output against your rules — do-not-translate, placeholder and tag integrity, terminology, and brand voice — and gate CI with `kapi verify`, which exits non-zero on failure so a regression never ships."
          }
        ],
        "nb": [
          {
            "text": "Verifiser AI-utdata mot reglene dine — ikke-oversett, plassholder- og kodeintegritet, terminologi og merkevarestemme — og sett port i CI med `kapi verify`, som avslutter med kode ulik null ved feil, så en regresjon aldri slipper ut."
          }
        ]
      },
      "origins": [
