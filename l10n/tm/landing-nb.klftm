    {
      "id": "landing-nb.tmx:tu-107@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Resolve a dropped placeholder, a translated product name, or an off-voice phrase — keeping meaning intact — then re-run the checks until they pass."
          }
        ],
        "nb": [
          {
            "text": "Rett en mistet plassholder, et oversatt produktnavn eller en formulering utenfor stemmen — uten å endre meningen — og kjør sjekkene på nytt til de passerer."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "landing-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-88cc79a04a89cc77-1781164979720993643"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb.tmx:tu-108@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Reuse with translation memory"
          }
        ],
        "nb": [
          {
            "text": "Gjenbruk med oversettelsesminne"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "landing-nb.tmx",
