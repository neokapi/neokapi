    {
      "id": "landing-nb:780fc82f85",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Checks are one part of the engine. Here is the brand-voice check up close: a generic AI draft for a marketing blog drifts off-voice, and kapi scores it against the brand profile and rewrites the violations — the same deterministic scorer the product ships."
          }
        ],
        "nb": [
          {
            "text": "Sjekker er én del av motoren. Her er merkevarestemmesjekken på nært hold: et generisk AI-utkast til en markedsføringsblogg driver ut av stemmen, og kapi poengsetter det mot merkevareprofilen og omskriver bruddene — samme deterministiske poengsetter som produktet leveres med."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:7828301209",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Any format, faithfully"
          }
        ],
        "nb": [
          {
            "text": "Alle formater, trofast"
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
