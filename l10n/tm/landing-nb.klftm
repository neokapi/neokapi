    {
      "id": "landing-nb:8d74d6d045",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Keep recipes, brand profiles, and termbases as version-controlled files alongside your code, and gate quality in CI. Open source, offline, no lock-in."
          }
        ],
        "nb": [
          {
            "text": "Hold oppskrifter, merkevareprofiler og termbaser som versjonskontrollerte filer ved siden av koden din, og sett kvalitetsport i CI. Åpen kildekode, frakoblet, ingen innlåsing."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:8f79ba211b",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Writing tools, brand-voice prompts, and localization services each tend to cover one slice. neokapi works across all three from a single content model."
          }
        ],
        "nb": [
          {
            "text": "Skriveverktøy, merkevarestemme-prompter og lokaliseringstjenester dekker gjerne hver sin del. neokapi arbeider på tvers av alle tre fra én felles innholdsmodell."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
