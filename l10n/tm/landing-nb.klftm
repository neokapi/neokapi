      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Native readers and writers for localization, document, data, subtitle, and office formats, with more through the okapi-bridge. A round-trip, not string-and-key extraction."
          }
        ],
        "nb": [
          {
            "text": "Innebygde lesere og skrivere for lokaliserings-, dokument-, data-, undertekst- og kontorformater, med flere gjennom okapi-bridge. En rundtur, ikke streng-og-nøkkel-uttrekk."
          }
        ]
      },
