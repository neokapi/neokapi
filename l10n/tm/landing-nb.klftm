      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "One binary, offline by default. Use the CLI for automation and CI, the MCP server inside your AI assistant, or the Desktop app for a visual workflow. No account required."
          }
        ],
        "nb": [
          {
            "text": "Én binærfil, frakoblet som standard. Bruk CLI-et for automatisering og CI, MCP-serveren i AI-assistenten din, eller Desktop-appen for en visuell arbeidsflyt. Ingen konto kreves."
          }
        ]
      },
      "origins": [
