      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Manage translation memories and terminology databases. Import, export, browse entries, and configure matching thresholds."
          }
        ],
        "nb": [
          {
            "text": "Administrer oversettelsesminner og termbaser. Importer, eksporter, bla i oppføringer og konfigurer terskler for treff."
          }
        ]
      },
      "origins": [
