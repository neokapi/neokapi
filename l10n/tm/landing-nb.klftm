      "id": "landing-nb.tmx:tu-10@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "AI alone 70/100"
          }
        ],
        "nb": [
          {
            "text": "{=m0} {=m1} AI alene {/=m0} {=m2} 70{=m3}/100{/=m3} {/=m2}"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
