      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "A single binary with embedded TM and termbase. Run entirely offline with local models, or opt into a cloud LLM — your call, not a default."
          }
        ],
        "nb": [
          {
            "text": "Én enkelt binærfil med innebygd oversettelsesminne og termbase. Kjør helt frakoblet med lokale modeller, eller velg en sky-LLM — ditt valg, ikke en standard."
          }
        ]
      },
      "origins": [
