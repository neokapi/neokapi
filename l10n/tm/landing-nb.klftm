    {
      "id": "landing-nb:d04db08612",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Prompt-only skills have no engine, scoring, or l10n."
          }
        ],
        "nb": [
          {
            "text": "Rene prompt-ferdigheter har ingen motor, scoring eller l10n."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:d1adb5f86f",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "One engine spans the whole pipeline: extract from any format, translate and check the content like you test code, then write the original back — faithfully."
          }
        ],
        "nb": [
          {
            "text": "Én motor dekker hele pipelinen: trekk ut fra hvilket som helst format, oversett og sjekk innholdet slik du tester kode, og skriv originalen tilbake — trofast."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:d3e009f755",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Structured key–value and tabular files — the catalogs apps ship strings in."
          }
        ],
        "nb": [
          {
            "text": "Strukturerte nøkkel–verdi- og tabellfiler — katalogene apper leverer strenger i."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:d500a8df1b",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Translation, terminology, QA, and voice scoring share one content model and one enforcement path — so what you ship stays consistent through every language."
          }
        ],
        "nb": [
          {
            "text": "Oversettelse, terminologi, QA og stemmescoring deler én innholdsmodell og én håndhevingsvei — så det du leverer holder seg konsistent gjennom hvert språk."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:d56842b8d2",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Verify AI output against your rules — do-not-translate, placeholder and tag integrity, terminology, and brand voice — and gate CI with `kapi verify`, which exits non-zero on failure so a regression never ships."
          }
        ],
        "nb": [
          {
            "text": "Verifiser AI-utdata mot reglene dine — ikke-oversett, plassholder- og kodeintegritet, terminologi og merkevarestemme — og sett port i CI med `kapi verify`, som avslutter med kode ulik null ved feil, så en regresjon aldri slipper ut."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:d6a7b3756c",
      "hintSrcLang": "en",
      "variants": {
