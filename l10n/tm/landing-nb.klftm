    {
      "id": "landing-nb:70f06e3f12",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Pull translatable text out of any format — DOCX, JSON, XLIFF, Markdown and more — into a clean structured view. The original structure, styles, and placeholders are remembered for a faithful write-back."
          }
        ],
        "nb": [
          {
            "text": "Hent tekst ut av hvilket som helst format — DOCX, JSON, XLIFF, Markdown og flere — til en ren, strukturert visning. Original struktur, stiler og plassholdere huskes for en trofast tilbakeskriving."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:7102842054",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Desktop app"
          }
        ],
