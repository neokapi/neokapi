          {
            "pcOpen": {
              "id": "1",
              "type": "jsx:element",
              "data": "{=m1}",
              "equiv": "=m1"
            }
          },
          {
            "text": "From any file to shipped, faithfully, in every language"
          },
          {
            "pcClose": {
              "id": "1",
              "type": "jsx:element",
              "data": "{/=m1}",
              "equiv": "=m1"
            }
