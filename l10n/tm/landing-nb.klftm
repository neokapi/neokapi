    },
    {
      "id": "landing-nb.tmx:tu-75@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Keep recipes, profiles, and termbases version-controlled and gate quality on every commit — the same checks locally and in your pipeline, exiting non-zero on failure."
          }
        ],
        "nb": [
          {
            "text": "Hold oppskrifter, profiler og termbaser versjonskontrollert, og sett kvalitetsport på hver commit — samme sjekker lokalt og i pipelinen din, med exit-kode ulik null ved feil."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "landing-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
