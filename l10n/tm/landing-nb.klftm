    {
      "id": "landing-nb:147e7d9dc2",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Native readers and writers for localization, document, data, subtitle, and office formats, with more through the okapi-bridge. A round-trip, not string-and-key extraction."
          }
        ],
        "nb": [
          {
            "text": "Innebygde lesere og skrivere for lokaliserings-, dokument-, data-, undertekst- og kontorformater, med flere gjennom okapi-bridge. En rundtur, ikke streng-og-nøkkel-uttrekk."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:167a4db2f3",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "An open engine that extracts what matters from any file, lets you translate, check, and transform it, and writes it back faithfully — structure, markup, and placeholders intact. AI translation, translation memory, terminology and brand checks built in. Offline by default — your content stays yours."
          },
          {
            "pcOpen": {
              "id": "1",
              "type": "jsx:element",
              "data": "{=m1}",
              "equiv": "=m1"
            }
          },
          {
            "pcClose": {
              "id": "1",
              "type": "jsx:element",
              "data": "{/=m1}",
              "equiv": "=m1"
            }
          }
        ],
        "nb": [
          {
            "text": "En åpen motor som trekker ut det som betyr noe fra hvilken som helst fil, lar deg oversette, sjekke og transformere det, og skriver det trofast tilbake — struktur, oppmerking og plassholdere intakt. AI-oversettelse, oversettelsesminne, terminologi- og merkevaresjekker innebygd. "
          },
          {
            "pcOpen": {
              "id": "1",
              "type": "jsx:element",
              "data": "{=m1}",
              "equiv": "=m1"
            }
          },
          {
            "text": "Frakoblet som standard — innholdet ditt forblir ditt."
          },
          {
            "pcClose": {
              "id": "1",
              "type": "jsx:element",
              "data": "{/=m1}",
              "equiv": "=m1"
            }
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:1809c24eaa",
