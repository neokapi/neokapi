{
  "schemaVersion": "1.0",
  "kind": "kapi-tm-format",
  "entries": [
    {
      "id": "landing-nb:01f58637fa",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "`kapi mcp` exposes the engine — extract, translate, check, term and TM lookup — to any MCP client: Claude Code, Cursor, Windsurf, and more."
          }
        ],
        "nb": [
          {
            "text": "`kapi mcp` tilbyr motoren — uttrekk, oversettelse, sjekker, term- og TM-oppslag — til enhver MCP-klient: Claude Code, Cursor, Windsurf og flere."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:0487d6382d",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Neokapi reimagines the proven Okapi Framework in Go for native speed and near-instant local processing. Experimental AI-based rewrites of Java filters run natively, while a bridge to Java gives full access to battle-tested Okapi filters and steps."
          }
        ],
        "nb": [
          {
            "text": "Neokapi nytenker det velprøvde Okapi-rammeverket i Go for nativ hastighet og nær umiddelbar lokal prosessering. Eksperimentelle AI-baserte omskrivinger av Java-filtre kjører innebygd, mens en bro til Java gir full tilgang til gjennomprøvde Okapi-filtre og -steg."
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:0a79c252c6",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Interchange"
          }
        ],
        "nb": [
          {
            "text": "Utveksling"
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb:0b533c959a",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Every format, natively"
          }
        ],
        "nb": [
          {
            "text": "Hvert format, innebygd"
          }
        ]
      },
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
