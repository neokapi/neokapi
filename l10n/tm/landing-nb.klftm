    {
      "id": "landing-nb.tmx:tu-143@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Writing tools, brand-voice prompts, and localization services each tend to cover one slice. neokapi works across all three from a single content model."
          }
        ],
        "nb": [
          {
            "text": "Skriveverktøy, merkevarestemme-prompter og lokaliseringstjenester dekker gjerne hver sin del. neokapi arbeider på tvers av alle tre fra én felles innholdsmodell."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "landing-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-88cc79a04a89cc77-1781164979720993643"
