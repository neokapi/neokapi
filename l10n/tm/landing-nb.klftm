      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "String-centric tools stop at JSON keys and PO files."
          }
        ],
        "nb": [
          {
            "text": "Strengsentrerte verktøy stopper ved JSON-nøkler og PO-filer."
