    {
      "id": "landing-nb.tmx:tu-102@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Read and write localization, data, content, subtitle, and office formats in place — with more through the okapi-bridge. The full list lives in the Format Reference."
          }
        ],
        "nb": [
          {
            "text": "Les og skriv lokaliserings-, data-, innholds-, undertekst- og kontorformater på plass — med flere gjennom okapi-bridge. Hele listen finnes i formatreferansen."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "landing-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-88cc79a04a89cc77-1781164979720993643"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb.tmx:tu-103@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Read any file and pull its text into blocks — structure, styles, fields, and placeholders preserved for a faithful round-trip back."
          }
        ],
        "nb": [
          {
            "text": "Les hvilken som helst fil og hent teksten inn i blokker — struktur, stiler, felter og plassholdere bevares for en trofast rundtur tilbake."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "landing-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-88cc79a04a89cc77-1781164979720993643"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "landing-nb.tmx:tu-104@tmx-88cc79a0",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Read, change, and ship content in any format ."
          }
        ],
        "nb": [
          {
            "text": "Les, endre og lever innhold i {=m1} hvilket som helst format {/=m1}."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
