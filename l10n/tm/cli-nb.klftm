    {
      "id": "cli-nb.tmx:tu17@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Create a new kapi project with a {name}.kapi recipe and an adjacent .kapi/ state directory. By default the project id is the current directory's basename and source/target locales are en / (none). Override with --name, --source-locale, --target-locale (repeatable). --framework <name> pre-fills the content mapping for a known stack's i18n catalogs (see 'kapi presets list --framework'): react-i18next, react-intl, nextjs, vue-i18n, flutter, angular."
          }
        ],
        "nb": [
          {
            "text": "Opprett et nytt kapi-prosjekt med en {name}.kapi-oppskrift og en tilhørende .kapi/-tilstandskatalog. Som standard er prosjekt-id-en navnet på gjeldende katalog, og kilde-/målspråk er en / (ingen). Overstyr med --name, --source-locale, --target-locale (kan gjentas). --framework <name> forhåndsutfyller innholdskartleggingen for i18n-katalogene til en kjent teknologistakk (se 'kapi presets list --framework'): react-i18next, react-intl, nextjs, vue-i18n, flutter, angular."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T06:47:08Z",
