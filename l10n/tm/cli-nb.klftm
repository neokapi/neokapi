    {
      "id": "cli-nb.tmx:tu59@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "List the files matched by the project's content collections (honoring the\nexclude list). With --stats, also show per-file block and word counts.\n\n  kapi ls\n  kapi ls src/\n  kapi ls --stats"
          }
        ],
        "nb": [
          {
            "text": "List filene som matches av prosjektets innholdssamlinger (med respekt for\nekskluderingslisten). Med --stats vises også antall blokker og ord per fil.\n\n  kapi ls\n  kapi ls src/\n  kapi ls --stats"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
