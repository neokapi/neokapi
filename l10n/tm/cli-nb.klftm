      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Emit bilingual XLIFF 2.x (default) or PO files for each target locale declared in a .kapi project, pre-filled from the project's translation memory. Each invocation writes one batch of outputs under .kapi/cache/extractions/<batch-id>/ plus one bilingual file per source → target pair in --out-dir (default \"out/\")."
          }
        ],
        "nb": [
          {
            "text": "Skriv tospråklige XLIFF 2.x-filer (standard) eller PO-filer for hvert målspråk som er deklarert i et .kapi-prosjekt, forhåndsutfylt fra prosjektets oversettelsesminne. Hver kjøring skriver én bunt med utdata under .kapi/cache/extractions/<batch-id>/ pluss én tospråklig fil per kilde → mål-par i --out-dir (standard \"out/\")."
          }
        ]
      },
