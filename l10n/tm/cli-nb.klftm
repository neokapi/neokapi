    {
      "id": "cli-nb.tmx:tu5@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "An import session is created every time a TMX file is imported. Each session records the file's SHA-256 hash, TMX header metadata, and the number of entries imported. Origins on TM entries point back to the session that added them so you can filter the TM by import source."
          }
        ],
        "nb": [
          {
            "text": "En importøkt opprettes hver gang en TMX-fil importeres. Hver økt registrerer filens SHA-256-hasj, TMX-headerens metadata og antall importerte enheter. Opphav på TM-enheter peker tilbake til økten som la dem til, slik at du kan filtrere oversettelsesminnet på importkilde."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T06:47:08Z",
