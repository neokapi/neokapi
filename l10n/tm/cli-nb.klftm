    {
      "id": "cli-nb.tmx:tu122@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Snapshot a .kapi project's working state — the block-store overlays, the authoritative translation memory, and the termbase — into a portable .klz. Regenerable caches and secrets are excluded. Move the snapshot to another machine and \"kapi unpack\" it to resume work there."
          }
        ],
        "nb": [
          {
            "text": "Ta et øyeblikksbilde av arbeidstilstanden i et .kapi-prosjekt — blokklagerets overlegg, det autoritative oversettelsesminnet og termbasen — til en portabel .klz. Regenererbare hurtigbuffere og hemmeligheter utelates. Flytt øyeblikksbildet til en annen maskin og kjør \"kapi unpack\" der for å fortsette arbeidet."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T06:47:08Z",
