      "id": "cli-nb.tmx:tu142@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "kapi helps you manage multilingual content — convert document formats, translate with AI, and run quality checks across a wide range of file types."
          }
        ],
        "nb": [
          {
            "text": "kapi hjelper deg å håndtere flerspråklig innhold — konverter dokumentformater, oversett med AI og kjør kvalitetskontroller på et bredt utvalg filtyper."
          }
        ]
      },
      "origins": [
