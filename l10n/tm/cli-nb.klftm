    {
      "id": "cli-nb.tmx:tu70@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Manage translation memory"
          }
        ],
        "nb": [
          {
            "text": "Administrer oversettelsesminne"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-cdd215754c1e270a-1781164979013541594"
        }
