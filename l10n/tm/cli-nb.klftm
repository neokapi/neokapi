      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Glue commands for AI coding assistants. Each subcommand reads the assistant's hook payload on stdin and writes the assistant's expected response on stdout. These are wired up by the assistant's plugin, not run by hand."
          }
        ],
        "nb": [
          {
            "text": "Limkommandoer for AI-kodeassistenter. Hver underkommando leser assistentens hook-nyttelast på stdin og skriver svaret assistenten forventer på stdout. Disse kobles opp av assistentens tillegg og kjøres ikke for hånd."
          }
        ]
      },
      "origins": [
