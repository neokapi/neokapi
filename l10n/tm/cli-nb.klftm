    {
      "id": "cli-nb.tmx:tu102@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Save an AI provider credential to the OS keychain. The credential name is used to reference it in flows and tool commands: kapi ai-translate --credential my-openai -i file.json --target-lang fr If only one credential is saved, tools will auto-detect it without --credential."
          }
        ],
        "nb": [
          {
            "text": "Lagre legitimasjon for en AI-leverandør i operativsystemets nøkkelring. Navnet på legitimasjonen brukes til å referere til den i flyter og verktøykommandoer: kapi ai-translate --credential my-openai -i file.json --target-lang fr Hvis bare én legitimasjon er lagret, finner verktøyene den automatisk uten --credential."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T06:47:08Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-cdd215754c1e270a-1781160428863464396"
