    {
      "id": "cli-nb.tmx:tu69@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Manage the bundled Agent Skills. These SKILL.md definitions teach an AI coding assistant (Claude Code, etc.) how to use kapi to keep generated content on-brand, terminologically consistent, and to publish multilingually. The kapi-* skills drive the local CLI; the bowrain-* skills drive the governed Bowrain platform."
          }
        ],
        "nb": [
          {
            "text": "Administrer de medfølgende Agent Skills. Disse SKILL.md-definisjonene lærer en AI-kodeassistent (Claude Code o.l.) hvordan den bruker kapi til å holde generert innhold i tråd med merkevaren, terminologisk konsistent, og til å publisere flerspråklig. kapi-*-skills driver den lokale CLI-en; bowrain-*-skills driver den styrte Bowrain-plattformen."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T06:47:08Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-cdd215754c1e270a-1781160428863464396"
        }
