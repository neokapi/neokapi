    {
      "id": "cli-nb.tmx:tu124@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Stop tracking files matching the given patterns.\n\nIf a pattern matches one added with 'kapi add', the mapping is removed.\nOtherwise the pattern is added to the exclude list so those files are skipped.\n\n  kapi rm \"src/**/*.html\"       # remove the mapping\n  kapi rm \"src/legacy/*.html\"   # exclude matching files"
          }
        ],
        "nb": [
          {
            "text": "Slutt å spore filer som matcher de angitte mønstrene.\n\nHvis et mønster matcher ett som ble lagt til med 'kapi add', fjernes kartleggingen.\nEllers legges mønsteret til i ekskluderingslisten slik at de filene hoppes over.\n\n  kapi rm \"src/**/*.html\"       # fjern kartleggingen\n  kapi rm \"src/legacy/*.html\"   # ekskluder samsvarende filer"
          }
        ]
      },
      "origins": [
