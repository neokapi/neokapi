    {
      "id": "cli-nb.tmx:tu67@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Manage project terminology. A termbase is a glossary of approved terms stored as a SQLite database. Use these commands to import, export, look up, and manage terms. Resource location (mutually exclusive): --name <n> Named termbase in KAPI_HOME (~/.config/kapi/termbases/<n>.db) --local Termbase in current directory (./termbase.db) --file <path> Explicit file path Default (no flag): same as --local (uses ./termbase.db)."
          }
        ],
        "nb": [
          {
            "text": "Administrer prosjektterminologi. En termbase er en ordliste med godkjente termer lagret som en SQLite-database. Bruk disse kommandoene til å importere, eksportere, slå opp og administrere termer. Ressursplassering (gjensidig utelukkende): --name <n> Navngitt termbase i KAPI_HOME (~/.config/kapi/termbases/<n>.db) --local Termbase i gjeldende katalog (./termbase.db) --file <path> Eksplisitt filsti Standard (uten flagg): samme som --local (bruker ./termbase.db)."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T06:47:08Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-cdd215754c1e270a-1781160428863464396"
        }
      ],
      "created": "2026-06-11T06:47:08Z",
      "updated": "2026-06-11T06:47:08Z"
    },
    {
      "id": "cli-nb.tmx:tu68@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Manage saved AI provider credentials"
          }
        ],
        "nb": [
          {
            "text": "Administrer lagret legitimasjon for AI-leverandører"
          }
        ]
      },
      "origins": [
