      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Install a plugin from a registry. The plugin is downloaded, verified (SHA-256 + cosign signature), and unpacked into $XDG_DATA_HOME/kapi/plugins/<name>/. Examples: kapi plugin install bowrain kapi plugin install bowrain@^1.0 kapi plugin install bowrain --channel beta"
          }
        ],
        "nb": [
          {
            "text": "Installer et tillegg fra et register. Tillegget lastes ned, verifiseres (SHA-256 + cosign-signatur) og pakkes ut i $XDG_DATA_HOME/kapi/plugins/<name>/. Eksempler: kapi plugin install bowrain kapi plugin install bowrain@^1.0 kapi plugin install bowrain --channel beta"
          }
        ]
      },
