    {
      "id": "cli-nb.tmx:tu136@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Update an installed plugin in place using the channel and constraint recorded at install time. Pass --channel or --constraint to switch tracks during update; --index points the update at a different registry index URL. Examples: kapi plugin update bowrain kapi plugin update bowrain --channel beta kapi plugin update bowrain --constraint ^2.0"
          }
        ],
        "nb": [
          {
            "text": "Oppdater et installert tillegg på stedet med kanalen og versjonskravet som ble registrert ved installasjon. Bruk --channel eller --constraint for å bytte spor under oppdateringen; --index peker oppdateringen mot en annen registerindeks-URL. Eksempler: kapi plugin update bowrain kapi plugin update bowrain --channel beta kapi plugin update bowrain --constraint ^2.0"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T06:47:08Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-cdd215754c1e270a-1781160428863464396"
        }
      ],
      "created": "2026-06-11T06:47:08Z",
      "updated": "2026-06-11T06:47:08Z"
    },
    {
      "id": "cli-nb.tmx:tu137@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Update an installed plugin to the latest matching version"
          }
        ],
        "nb": [
          {
            "text": "Oppdater et installert tillegg til nyeste samsvarende versjon"
          }
        ]
      },
