    {
      "id": "cli-nb.tmx:tu33@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Import a single TMX file (plain or .gz) into the TM. By default, imports entries matching the given --source-locale and --target-locale. Use --all-pairs to emit entries for every (src, tgt) language pair present in each TU — useful for multilingual TMX files (e.g. EUR-Lex Euramis exports where a single TU may contain 24+ languages). Combine with --locales to restrict the pair set (e.g. --all-pairs --locales en-GB,fr-FR,de-DE). The importer auto-detects UTF-8/UTF-16 from the BOM, so Euramis exports work without pre-conversion. For web-crawl TMX sets (bitextor output) the per-TUV <prop type=\"source-document\"> URL is recorded as Origin.Reference."
          }
        ],
        "nb": [
          {
            "text": "Importer én TMX-fil (ren eller .gz) til oversettelsesminnet. Som standard importeres enheter som samsvarer med angitt --source-locale og --target-locale. Bruk --all-pairs for å skrive enheter for hvert (kilde, mål)-språkpar som finnes i hver TU — nyttig for flerspråklige TMX-filer (f.eks. EUR-Lex Euramis-eksporter der én TU kan inneholde over 24 språk). Kombiner med --locales for å begrense parsettet (f.eks. --all-pairs --locales en-GB,fr-FR,de-DE). Importen gjenkjenner UTF-8/UTF-16 automatisk fra BOM-en, så Euramis-eksporter fungerer uten forhåndskonvertering. For TMX-sett fra webcrawl (bitextor-utdata) registreres URL-en i <prop type=\"source-document\"> per TUV som Origin.Reference."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T06:47:08Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-cdd215754c1e270a-1781160428863464396"
        }
      ],
      "created": "2026-06-11T06:47:08Z",
      "updated": "2026-06-11T06:47:08Z"
    },
