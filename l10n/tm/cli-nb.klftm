    {
      "id": "cli-nb.tmx:tu12@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Check, rewrite, and govern content against a brand voice profile. Profile source (mutually exclusive): --profile <name> Profile in the local brand store (see 'kapi brand profiles') --profile-file <path> Standalone profile YAML (git-shareable, no store needed) --pack <name> Built-in starter pack (professional-b2b, friendly-dtc, technical-docs, marketing-blog, customer-support) Text input for check/rewrite is read from --text, or from stdin when --text is omitted or set to \"-\"."
          }
        ],
        "nb": [
          {
            "text": "Kontroller, omskriv og styr innhold mot en merkevarestemmeprofil. Profilkilde (gjensidig utelukkende): --profile <name> Profil i det lokale merkevarelageret (se 'kapi brand profiles') --profile-file <path> Frittstående profil-YAML (git-delbar, krever ikke lager) --pack <name> Innebygd startpakke (professional-b2b, friendly-dtc, technical-docs, marketing-blog, customer-support) Tekst til check/rewrite leses fra --text, eller fra stdin når --text er utelatt eller satt til \"-\"."
          }
        ]
      },
