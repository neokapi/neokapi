    {
      "id": "cli-nb.tmx:tu102@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Save an AI provider credential to the OS keychain.\n\nThe credential name is used to reference it in flows and tool commands:\n  kapi ai-translate --credential my-openai -i file.json --target-lang fr\n\nIf only one credential is saved, tools will auto-detect it without --credential."
          }
        ],
        "nb": [
          {
            "text": "Lagre legitimasjon for en AI-leverandør i operativsystemets nøkkelring.\n\nNavnet på legitimasjonen brukes til å referere til den i flyter og verktøykommandoer:\n  kapi ai-translate --credential my-openai -i file.json --target-lang fr\n\nHvis bare én legitimasjon er lagret, finner verktøyene den automatisk uten --credential."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-cdd215754c1e270a-1781164979013541594"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
