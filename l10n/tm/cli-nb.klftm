    {
      "id": "cli-nb.tmx:tu23@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Export the TM to TMX 1.4 format. Each entry is written as a single\n<tu> with one <tuv> per language variant present (or the subset requested\nvia --locales). Inline markup is preserved as TMX <ph>/<bpt>/<ept>/<it>/<hi>.\n\nBy default all variants on every entry are emitted. Pass --locales to\nrestrict to a subset (comma-separated)."
          }
        ],
        "nb": [
          {
            "text": "Eksporter oversettelsesminnet til TMX 1.4-format. Hver enhet skrives som én\n<tu> med én <tuv> per språkvariant som finnes (eller utvalget som er bedt om\nmed --locales). Inline-merking bevares som TMX <ph>/<bpt>/<ept>/<it>/<hi>.\n\nSom standard skrives alle varianter på hver enhet. Bruk --locales for å\nbegrense til et utvalg (kommaseparert)."
          }
        ]
      },
      "origins": [
