      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Snapshot a .kapi project's working state into a .klz"
          }
        ],
        "nb": [
          {
            "text": "Ta øyeblikksbilde av arbeidstilstanden i et .kapi-prosjekt til en .klz"
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T06:47:08Z",
