    },
    {
      "id": "cli-nb.tmx:tu69@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Manage the bundled Agent Skills.\n\nThese SKILL.md definitions teach an AI coding assistant (Claude Code, etc.) how\nto use kapi to keep generated content on-brand, terminologically consistent, and\nto publish multilingually. The kapi-* skills drive the local CLI; the bowrain-*\nskills drive the governed Bowrain platform."
          }
        ],
        "nb": [
          {
            "text": "Administrer de medfølgende Agent Skills.\n\nDisse SKILL.md-definisjonene lærer en AI-kodeassistent (Claude Code o.l.) hvordan\nden bruker kapi til å holde generert innhold i tråd med merkevaren, terminologisk\nkonsistent, og til å publisere flerspråklig. kapi-*-skills driver den lokale\nCLI-en; bowrain-*-skills driver den styrte Bowrain-plattformen."
          }
        ]
      },
      "origins": [
        {
          "source": "import",
          "key": "cli-nb.tmx",
          "addedAt": "2026-06-11T08:02:59Z",
          "addedBy": "kapi tm import",
          "sessionId": "tmx-cdd215754c1e270a-1781164979013541594"
        }
      ],
      "created": "2026-06-11T08:02:59Z",
      "updated": "2026-06-11T08:02:59Z"
    },
    {
      "id": "cli-nb.tmx:tu6@tmx-cdd21575",
      "hintSrcLang": "en",
      "variants": {
        "en": [
          {
            "text": "Analysis"
          }
        ],
        "nb": [
          {
            "text": "Analyse"
          }
        ]
      },
      "origins": [
