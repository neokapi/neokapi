{
  "formats": [
    {
      "id": "archive",
      "displayName": "ZIP Archive",
      "description": "ZIP archive extraction with glob-based file filtering for translatable content",
      "extensions": [
        ".zip"
      ],
      "mimeTypes": [
        "application/zip",
        "application/x-zip-compressed"
      ],
      "hasReader": true,
      "hasWriter": true,
      "groups": [
        {
          "id": "extraction",
          "label": "Extraction",
          "fields": [
            "filePatterns"
          ]
        }
      ],
      "properties": {
        "filePatterns": {
          "type": "array",
          "description": "Glob patterns for files to extract (e.g., \"*.txt\", \"*.xml\"). If empty, common text file patterns are used.",
          "default": ["*.txt", "*.xml", "*.json", "*.yaml", "*.csv", "*.po", "*.xliff"]
        }
      }
    },
    {
      "id": "csv",
      "displayName": "CSV",
      "description": "Comma-separated values with column-level extraction control",
      "extensions": [
        ".csv"
      ],
      "mimeTypes": [
        "text/csv"
      ],
      "hasReader": true,
      "hasWriter": true,
      "groups": [
        {
          "id": "parsing",
          "label": "Parsing",
          "fields": [
            "separator",
            "hasHeader"
          ]
        },
        {
          "id": "extraction",
          "label": "Extraction",
          "fields": [
            "translatableColumns",
            "keyColumns",
            "commentColumns"
          ]
        },
        {
          "id": "advanced",
          "label": "Advanced",
          "collapsed": true,
          "fields": [
            "trimValues",
            "valuesStartRow",
            "columnNamesRow"
          ]
        }
      ],
      "properties": {
        "hasHeader": {
          "type": "boolean",
          "description": "If true, the first row is treated as headers (non-translatable)",
          "default": true
        },
        "separator": {
          "type": "string",
          "description": "Field delimiter character",
          "default": ","
        },
        "translatableColumns": {
          "type": "array",
          "description": "Column indices (0-based) to extract as translatable content. If empty, all columns are translatable."
        },
        "keyColumns": {
          "type": "array",
          "description": "Column indices (0-based) whose values are used as block IDs"
        },
        "commentColumns": {
          "type": "array",
          "description": "Column indices (0-based) whose values become notes on the translatable block"
        },
        "trimValues": {
          "type": "boolean",
          "description": "Trim whitespace from cell values",
          "default": false
        },
        "valuesStartRow": {
          "type": "number",
          "description": "Row number (0-based) where translatable data starts",
          "default": 0
        },
        "columnNamesRow": {
          "type": "number",
          "description": "Row number (0-based) containing column names",
          "default": 0
        }
      }
    },
    {
      "id": "doxygen",
      "displayName": "Doxygen Comments",
      "description": "Doxygen/Javadoc comment extraction from source code files",
      "extensions": [
        ".c",
        ".cpp",
        ".h",
        ".java",
        ".m",
        ".py"
      ],
      "mimeTypes": [
        "text/x-doxygen-txt"
      ],
      "hasReader": true,
      "hasWriter": true
    },
    {
      "id": "dtd",
      "displayName": "DTD",
      "description": "XML Document Type Definition — extracts entity values",
      "extensions": [
        ".dtd"
      ],
      "mimeTypes": [
        "application/xml-dtd"
      ],
      "hasReader": true,
      "hasWriter": true
    },
    {
      "id": "epub",
      "displayName": "EPUB E-Book",
      "description": "EPUB 2/3 e-book extraction",
      "extensions": [
        ".epub"
      ],
      "mimeTypes": [
        "application/epub+zip"
      ],
      "hasReader": true,
      "hasWriter": true
    },
    {
      "id": "fixedwidth",
      "displayName": "Fixed-Width",
      "description": "Fixed-width column text files with configurable column definitions",
      "extensions": [
        ".txt",
        ".dat",
        ".fixed"
      ],
      "mimeTypes": [
        "text/plain"
      ],
      "hasReader": true,
      "hasWriter": true,
      "groups": [
        {
          "id": "columns",
          "label": "Column Definitions",
          "fields": [
            "columns"
          ]
        },
        {
          "id": "parsing",
          "label": "Parsing",
          "fields": [
            "hasHeader",
            "trimValues"
          ]
        }
      ],
      "properties": {
        "columns": {
          "type": "array",
          "description": "Column definitions: each entry has name (string), start (0-based position), width (in runes), and translatable (boolean)"
        },
        "hasHeader": {
          "type": "boolean",
          "description": "If true, the first row is treated as a header",
          "default": false
        },
        "trimValues": {
          "type": "boolean",
          "description": "Trim whitespace from column values",
          "default": false
        }
      }
    },
    {
      "id": "html",
      "displayName": "HTML",
      "description": "HTML documents with configurable element/attribute extraction rules and inline code detection",
      "extensions": [
        ".html",
        ".htm",
        ".xhtml"
      ],
      "mimeTypes": [
        "text/html",
        "application/xhtml+xml"
      ],
      "hasReader": true,
      "hasWriter": true,
      "groups": [
        {
          "id": "parser",
          "label": "Parser Settings",
          "fields": [
            "preserveWhitespace"
          ]
        },
        {
          "id": "extraction",
          "label": "Extraction Rules",
          "fields": [
            "elements",
            "attributes"
          ]
        },
        {
          "id": "inlineCodes",
          "label": "Inline Codes",
          "fields": [
            "useCodeFinder",
            "codeFinderRules"
          ]
        }
      ],
      "properties": {
        "attributes": {
          "type": "object",
          "description": "Map of attribute names to extraction rules (ruleTypes, allElementsExcept, onlyTheseElements, conditions)"
        },
        "codeFinderRules": {
          "type": "array",
          "description": "Regex patterns that match inline codes within translatable text"
        },
        "elements": {
          "type": "object",
          "description": "Map of element names to extraction rules (ruleTypes, conditions, idAttributes, translatableAttributes)"
        },
        "preserveWhitespace": {
          "type": "boolean",
          "description": "Preserve significant whitespace in text nodes",
          "default": false
        },
        "useCodeFinder": {
          "type": "boolean",
          "description": "Enable regex-based inline code detection",
          "default": false
        }
      }
    },
    {
      "id": "icml",
      "displayName": "ICML (Adobe InCopy)",
      "description": "Adobe InCopy Markup Language with note and line-break handling",
      "extensions": [
        ".icml",
        ".wcml"
      ],
      "mimeTypes": [
        "application/x-icml+xml"
      ],
      "hasReader": true,
      "hasWriter": true,
      "groups": [
        {
          "id": "extraction",
          "label": "Extraction",
          "fields": [
            "extractNotes",
            "newTUOnBr"
          ]
        }
      ],
      "properties": {
        "extractNotes": {
          "type": "boolean",
          "description": "Extract InCopy notes as translatable content",
          "default": false
        },
        "newTUOnBr": {
          "type": "boolean",
          "description": "Start a new translation unit on <Br/> elements",
          "default": false
        }
      }
    },
    {
      "id": "idml",
      "displayName": "IDML (Adobe InDesign)",
      "description": "Adobe InDesign Markup Language with master spread and note extraction",
      "extensions": [
        ".idml"
      ],
      "mimeTypes": [
        "application/vnd.adobe.indesign-idml-package"
      ],
      "hasReader": true,
      "hasWriter": true,
      "groups": [
        {
          "id": "extraction",
          "label": "Extraction",
          "fields": [
            "extractMasterSpreads",
            "extractNotes",
            "skipDiscretionaryHyphens"
          ]
        }
      ],
      "properties": {
        "extractMasterSpreads": {
          "type": "boolean",
          "description": "Extract content from master spreads",
          "default": false
        },
        "extractNotes": {
          "type": "boolean",
          "description": "Extract InDesign notes as translatable content",
          "default": true
        },
        "skipDiscretionaryHyphens": {
          "type": "boolean",
          "description": "Skip discretionary hyphen characters during extraction",
          "default": true
        }
      }
    },
    {
      "id": "json",
      "displayName": "JSON",
      "description": "Highly configurable JSON extraction with regex-based rules for extraction, notes, IDs, metadata, and subfilters",
      "extensions": [
        ".json"
      ],
      "mimeTypes": [
        "application/json"
      ],
      "hasReader": true,
      "hasWriter": true,
      "groups": [
        {
          "id": "extraction",
          "label": "Extraction",
          "fields": [
            "extractAllPairs",
            "exceptions",
            "extractIsolatedStrings",
            "extractionRules"
          ]
        },
        {
          "id": "naming",
          "label": "Block Naming",
          "fields": [
            "useKeyAsName",
            "useFullKeyPath",
            "useLeadingSlashOnKeyPath",
            "idRules",
            "useIdStack"
          ]
        },
        {
          "id": "subfilters",
          "label": "Subfilters",
          "fields": [
            "subfilters",
            "subfilter",
            "subfilterRules"
          ]
        },
        {
          "id": "metadata",
          "label": "Metadata",
          "fields": [
            "noteRules",
            "genericMetaRules",
            "maxwidthRules",
            "maxwidthSizeUnit"
          ]
        },
        {
          "id": "output",
          "label": "Output",
          "fields": [
            "escapeForwardSlashes"
          ]
        },
        {
          "id": "inlineCodes",
          "label": "Inline Codes",
          "fields": [
            "useCodeFinder",
            "codeFinderRules"
          ]
        }
      ],
      "properties": {
        "codeFinderRules": {
          "type": "array",
          "description": "Regex patterns that match inline codes within translatable text"
        },
        "escapeForwardSlashes": {
          "type": "boolean",
          "description": "Escape / as \\/ in JSON output",
          "default": true
        },
        "exceptions": {
          "type": "string",
          "description": "Regex pattern for key names. When extractAllPairs is true, matching keys are excluded. When false, matching keys are included."
        },
        "extractAllPairs": {
          "type": "boolean",
          "description": "Extract all string key-value pairs as translatable blocks",
          "default": true
        },
        "extractIsolatedStrings": {
          "type": "boolean",
          "description": "Extract standalone string values inside arrays as translatable blocks",
          "default": false
        },
        "extractionRules": {
          "type": "string",
          "description": "Regex pattern limiting which keys are extracted. Only matching keys are extracted.",
          "widget": "regexBuilder"
        },
        "genericMetaRules": {
          "type": "string",
          "description": "Regex pattern for key names whose values become metadata annotations"
        },
        "idRules": {
          "type": "string",
          "description": "Regex pattern for key names whose values are used as block names/IDs"
        },
        "maxwidthRules": {
          "type": "string",
          "description": "Regex pattern for key names whose numeric values set MAX_WIDTH on the next block"
        },
        "maxwidthSizeUnit": {
          "type": "string",
          "description": "Size unit for maxwidth: 'pixel' or 'char'",
          "default": "pixel"
        },
        "noteRules": {
          "type": "string",
          "description": "Regex pattern for key names whose values become notes on the next translatable block"
        },
        "subfilter": {
          "type": "string",
          "description": "Global subfilter format name (e.g., 'html') applied to all or matching extracted strings"
        },
        "subfilterRules": {
          "type": "string",
          "description": "Regex pattern for key names processed by the subfilter. Only used when subfilter is set."
        },
        "subfilters": {
          "type": "array",
          "description": "Array of {pattern, format} mappings for embedded content in specific keys"
        },
        "useCodeFinder": {
          "type": "boolean",
          "description": "Enable regex-based inline code detection",
          "default": false
        },
        "useFullKeyPath": {
          "type": "boolean",
          "description": "Use hierarchical paths (parent/child) as block names",
          "default": false
        },
        "useIdStack": {
          "type": "boolean",
          "description": "Stack IDs for nested structures, producing compound IDs",
          "default": false
        },
        "useKeyAsName": {
          "type": "boolean",
          "description": "Use the JSON key as the block name/ID",
          "default": true
        },
        "useLeadingSlashOnKeyPath": {
          "type": "boolean",
          "description": "Prepend / to full key paths",
          "default": true
        }
      },
      "presets": [
        {
          "id": "json-i18next",
          "name": "i18next",
          "description": "i18next JSON resource files with full key paths and HTML subfilter for *_html keys",
          "parameters": {
            "subfilter": "html",
            "subfilterRules": "_html$",
            "useFullKeyPath": true
          }
        },
        {
          "id": "json-chrome-extension",
          "name": "Chrome Extension",
          "description": "Chrome extension messages.json format (extract 'message' keys, 'description' as notes)",
          "parameters": {
            "exceptions": "^message$",
            "extractAllPairs": false,
            "noteRules": "^description$"
          }
        }
      ]
    },
    {
      "id": "markdown",
      "displayName": "Markdown",
      "description": "Markdown with control over code blocks, front matter, image alt text, URLs, blockquotes, and HTML blocks",
      "extensions": [
        ".md",
        ".markdown"
      ],
      "mimeTypes": [
        "text/markdown",
        "text/x-markdown"
      ],
      "hasReader": true,
      "hasWriter": true,
      "groups": [
        {
          "id": "extraction",
          "label": "Content Extraction",
          "fields": [
            "translateCodeBlocks",
            "translateFrontMatter",
            "translateImageAlt",
            "translateURLs",
            "translateBlockQuotes",
            "translateHTMLBlocks"
          ]
        }
      ],
      "properties": {
        "translateBlockQuotes": {
          "type": "boolean",
          "description": "If true, blockquote content is translatable.",
          "default": true
        },
        "translateCodeBlocks": {
          "type": "boolean",
          "description": "If true, fenced/indented code blocks are translatable. If false, emitted as non-translatable data.",
          "default": false
        },
        "translateFrontMatter": {
          "type": "boolean",
          "description": "If true, YAML front matter values are translatable. If false, emitted as non-translatable data.",
          "default": false
        },
        "translateHTMLBlocks": {
          "type": "boolean",
          "description": "If true, raw HTML blocks are translatable. If false, emitted as non-translatable data.",
          "default": false
        },
        "translateImageAlt": {
          "type": "boolean",
          "description": "If true, image alt text is included in translatable content.",
          "default": true
        },
        "translateURLs": {
          "type": "boolean",
          "description": "If true, link and image URLs are translatable.",
          "default": false
        }
      }
    },
    {
      "id": "messageformat",
      "displayName": "ICU MessageFormat",
      "description": "ICU MessageFormat extraction for pluralization and gender handling",
      "extensions": [
        ".mf",
        ".messageformat"
      ],
      "mimeTypes": [
        "text/x-messageformat"
      ],
      "hasReader": true,
      "hasWriter": true
    },
    {
      "id": "mif",
      "displayName": "Adobe FrameMaker MIF",
      "description": "Adobe FrameMaker Maker Interchange Format",
      "extensions": [
        ".mif"
      ],
      "mimeTypes": [
        "application/x-mif",
        "application/vnd.mif"
      ],
      "hasReader": true,
      "hasWriter": true
    },
    {
      "id": "mosestext",
      "displayName": "Moses Text",
      "description": "Moses machine translation plain text format — one translatable segment per line",
      "extensions": [
        ".txt"
      ],
      "mimeTypes": [
        "text/x-mosestext"
      ],
      "hasReader": true,
      "hasWriter": true
    },
    {
      "id": "odf",
      "displayName": "Open Document Format",
      "description": "ODF documents (ODT, ODS, ODP) with note and hidden content handling",
      "extensions": [
        ".odt",
        ".ods",
        ".odp"
      ],
      "mimeTypes": [
        "application/vnd.oasis.opendocument.text"
      ],
      "hasReader": true,
      "hasWriter": true,
      "groups": [
        {
          "id": "extraction",
          "label": "Extraction",
          "fields": [
            "translateNotes",
            "translateHiddenContent"
          ]
        }
      ],
      "properties": {
        "translateNotes": {
          "type": "boolean",
          "description": "Extract document notes as translatable content",
          "default": true
        },
        "translateHiddenContent": {
          "type": "boolean",
          "description": "Extract hidden text and hidden sections",
          "default": false
        }
      }
    },
    {
      "id": "openxml",
      "displayName": "Office Open XML",
      "description": "Microsoft Office formats (Word, Excel, PowerPoint) with extensive extraction controls",
      "extensions": [
        ".docx",
        ".docm",
        ".dotx",
        ".dotm",
        ".xlsx",
        ".xlsm",
        ".xltx",
        ".xltm",
        ".pptx",
        ".pptm",
        ".ppsx",
        ".potx"
      ],
      "mimeTypes": [
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "application/vnd.openxmlformats-officedocument.presentationml.presentation",
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
      ],
      "hasReader": true,
      "hasWriter": true,
      "groups": [
        {
          "id": "common",
          "label": "Common Extraction",
          "fields": [
            "translateDocProperties",
            "translateHiddenText",
            "translateHeadersFooters",
            "translateFootnotes",
            "translateComments",
            "translateHyperlinks"
          ]
        },
        {
          "id": "formatting",
          "label": "Formatting Control",
          "fields": [
            "aggressiveCleanup",
            "tabAsCharacter"
          ]
        },
        {
          "id": "pptx",
          "label": "PowerPoint Options",
          "collapsed": true,
          "fields": [
            "translateSlideNotes",
            "translateSlideMasters",
            "translateHiddenSlides",
            "translateCharts",
            "translateDiagrams",
            "includedSlides"
          ]
        },
        {
          "id": "xlsx",
          "label": "Excel Options",
          "collapsed": true,
          "fields": [
            "translateSheetNames",
            "translateSharedStrings",
            "excludedSheets",
            "excludedColumns"
          ]
        },
        {
          "id": "styles",
          "label": "Style & Color Filtering",
          "collapsed": true,
          "fields": [
            "excludeColors",
            "excludeHighlightColors",
            "includeHighlightColors",
            "excludeStyles",
            "includeStyles"
          ]
        },
        {
          "id": "inlineCodes",
          "label": "Inline Codes",
          "collapsed": true,
          "fields": [
            "useCodeFinder",
            "codeFinderRules"
          ]
        },
        {
          "id": "advanced",
          "label": "Advanced",
          "collapsed": true,
          "fields": [
            "complexFieldDefinitionsToExtract",
            "optimiseWordStyles",
            "fontMappings",
            "extractRunFontsInfo",
            "replaceLineSeparator",
            "lineSeparatorReplacement"
          ]
        }
      ],
      "properties": {
        "aggressiveCleanup": {
          "type": "boolean",
          "description": "Strip revision IDs, proofing errors, and other noise before merging runs",
          "default": true
        },
        "codeFinderRules": {
          "type": "array",
          "description": "Regex patterns that match inline codes within translatable text"
        },
        "complexFieldDefinitionsToExtract": {
          "type": "array",
          "description": "Field instruction prefixes to extract (e.g., \"HYPERLINK\", \"REF\")"
        },
        "excludeColors": {
          "type": "array",
          "description": "Font colors to exclude (hex RGB, e.g., \"FF0000\" for red)"
        },
        "excludeHighlightColors": {
          "type": "array",
          "description": "Highlight colors to exclude (e.g., \"yellow\", \"red\")"
        },
        "excludeStyles": {
          "type": "array",
          "description": "Paragraph/character style names to exclude"
        },
        "excludedColumns": {
          "type": "array",
          "description": "Column letters to exclude (e.g., \"A\", \"C\", \"AA\")"
        },
        "excludedSheets": {
          "type": "array",
          "description": "Sheet names to exclude from extraction"
        },
        "extractRunFontsInfo": {
          "type": "boolean",
          "description": "Emit font metadata as annotations on blocks",
          "default": false
        },
        "fontMappings": {
          "type": "object",
          "description": "Font name to script group mapping (e.g., \"MS Gothic\": \"ja\")"
        },
        "includeHighlightColors": {
          "type": "array",
          "description": "If non-empty, only extract text with these highlight colors"
        },
        "includeStyles": {
          "type": "array",
          "description": "If non-empty, only extract text with these styles"
        },
        "includedSlides": {
          "type": "array",
          "description": "If non-empty, only extract these slide numbers (1-based)"
        },
        "lineSeparatorReplacement": {
          "type": "string",
          "description": "Replacement string for line separator characters",
          "default": "\n"
        },
        "optimiseWordStyles": {
          "type": "boolean",
          "description": "Resolve style inheritance and strip redundant run properties",
          "default": false
        },
        "replaceLineSeparator": {
          "type": "boolean",
          "description": "Replace Unicode line separator (U+2028) in output",
          "default": false
        },
        "tabAsCharacter": {
          "type": "boolean",
          "description": "Treat tab elements as tab characters instead of placeholder spans",
          "default": false
        },
        "translateCharts": {
          "type": "boolean",
          "description": "Extract strings from embedded charts",
          "default": false
        },
        "translateComments": {
          "type": "boolean",
          "description": "Extract comment text",
          "default": false
        },
        "translateDiagrams": {
          "type": "boolean",
          "description": "Extract text from SmartArt diagrams",
          "default": false
        },
        "translateDocProperties": {
          "type": "boolean",
          "description": "Extract title, subject, keywords from document properties",
          "default": true
        },
        "translateFootnotes": {
          "type": "boolean",
          "description": "Extract footnotes and endnotes",
          "default": true
        },
        "translateHeadersFooters": {
          "type": "boolean",
          "description": "Extract headers and footers",
          "default": true
        },
        "translateHiddenSlides": {
          "type": "boolean",
          "description": "Extract content from hidden slides",
          "default": false
        },
        "translateHiddenText": {
          "type": "boolean",
          "description": "Extract text with the vanish (hidden) property",
          "default": false
        },
        "translateHyperlinks": {
          "type": "boolean",
          "description": "Extract hyperlink text",
          "default": true
        },
        "translateSharedStrings": {
          "type": "boolean",
          "description": "Extract shared strings",
          "default": true
        },
        "translateSheetNames": {
          "type": "boolean",
          "description": "Extract sheet names as translatable content",
          "default": false
        },
        "translateSlideMasters": {
          "type": "boolean",
          "description": "Extract text from slide masters",
          "default": false
        },
        "translateSlideNotes": {
          "type": "boolean",
          "description": "Extract slide notes",
          "default": true
        },
        "useCodeFinder": {
          "type": "boolean",
          "description": "Enable regex-based inline code detection",
          "default": false
        }
      }
    },
    {
      "id": "paraplaintext",
      "displayName": "Paragraph Plain Text",
      "description": "Plain text segmented by paragraphs (blank line separators)",
      "extensions": [
        ".txt"
      ],
      "mimeTypes": [
        "text/plain"
      ],
      "hasReader": true,
      "hasWriter": true
    },
    {
      "id": "pdf",
      "displayName": "PDF",
      "description": "PDF text extraction",
      "extensions": [
        ".pdf"
      ],
      "mimeTypes": [
        "application/pdf"
      ],
      "hasReader": true,
      "hasWriter": true
    },
    {
