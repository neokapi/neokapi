# Build artifacts
bin/
__pycache__/
*.pyc
/bowrain-server
/actionlint
coverage/
# Go build outputs that land alongside their cmd dirs (not source).
/bowrain/cli/bowrain
/bowrain/cli/kapi-bowrain
/bowrain/cli/cmd/kapi-bowrain/kapi-bowrain
/gen-format-docs
# Default kapi DB created when running outside a project dir.
.neokapi.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Go
vendor/

# Plugin binaries
neokapi-plugin-*
*.exe

# Okapi filter test data (fetched from GitHub release)
okapi-testdata/
okapi-surefire/
compat-report/

# Tier B format corpora fetched from the format-corpus-vN release
# (make fetch-corpus) and the local publish staging area
# (scripts/publish-corpus.sh). Anchored to the repo root: the committed
# core/formats/<id>/testdata/corpus/ exemplars must stay tracked.
/corpus/
/corpus-staging/

# Frontend
node_modules/
dist/
!/bowrain/apps/bowrain/frontend/dist/.gitkeep
*.tsbuildinfo
**/public/version.json

# Extraction artifacts — regenerated via `make kapi-desktop-translations`.
# The per-locale runtime dictionaries under public/translations/ are
# committed so the app ships with translations; the intermediate
# per-file .klf extract output is ephemeral and gitignored.
apps/kapi-desktop/frontend/i18n/
apps/kapi-desktop/frontend/i18n-qps/
apps/kapi-desktop/frontend/i18n-nb/

# Dogfood project state for the root neokapi.kapi recipe — rebuilt from the
# committed seeds via `make l10n-seed`.
/.kapi/
# Disposable TMX/CSV review views of the native l10n seeds (l10n-review-export).
/l10n/review/

# Wails
**/build/bin/
**/build/darwin/
!platform/apps/bowrain/build/darwin/
!framework/apps/kapi-desktop/build/darwin/
**/build/appicon.png
!platform/apps/bowrain/build/appicon.png
!framework/apps/kapi-desktop/build/appicon.png
**/frontend/wailsjs/
**/frontend/bindings/
!bowrain/apps/bowrain/frontend/bindings/
!apps/kapi-desktop/frontend/bindings/
**/frontend/package.json.md5
**/.task/

# Keycloak theme build output
dist_keycloak/

# Keycloak provider JARs (downloaded for local dev)
platform/docker/keycloak/*.jar

# Dev server
.bowrain-server.pid
bowrain-dev.db*
bowrain-e2e.db*
bowrain-ci.db*

# Storybook
storybook-static/

# Playwright
test-results/
playwright-report/
# kapi docs scene fixtures stay tracked; any transient recordings or
# screenshots under web/scenes/ are build artifacts, not source.
web/scenes/**/*.webm
web/scenes/**/*.mp4
web/scenes/**/*.mov
web/scenes/**/*.gif
web/scenes/**/*.png
web/scenes/**/*.jpg

# Local TLS certs (mkcert)
docker/traefik/certs/

# Docusaurus

# In-browser playground wasm artifacts (built by `make web-wasm-demo` / CI)
web/static/wasm/
bowrain/web/landing/dist/
web/build/
web/.docusaurus/

# Generated per-entry reference pages (R4, #673). One MDX per command / format /
# tool, produced by web/scripts/gen-reference-pages.ts from
# @neokapi/reference-data via the prebuild/prestart hooks. Regenerated, not
# committed. The hand-written reference/index.mdx (R1) is kept.
web/reference/commands/
web/reference/formats/
web/reference/tools/

# Generated documentation assets (fetched from docs-assets release in CI)
web/static/img/bowrain/
web/static/img/web-app/
web/static/video/
web/static/data/test-comparison.json
bowrain/apps/bowrain/frontend/recordings-output/
bowrain/web/docs/build/
bowrain/web/docs/.docusaurus/
bowrain/website/node_modules/
bowrain/web/docs/static/img/bowrain/
bowrain/web/docs/static/img/web-app/
bowrain/web/docs/static/video/
web/tapes/output/
web/tapes/out/
web/tapes/.server-token

# Remotion video pipeline
website/videos/output/
website/videos/public/raw/
.java-version
.claude/worktrees/
.env
.env.local
platform/docker/traefik/certs
.playwright-mcp/
.parity/
.contract-audit/

# Generated kapi/bowrain skill copies. The canonical source is cli/skills/data/
# (embedded in the binary). Regenerate the dogfood copies with `make dev-skills`
# and the Claude Code plugin bundle with `make plugin-bundle`. Hand-authored
# skills (e.g. .claude/skills/walkthrough-*) stay committed and are not ignored.
/.claude/skills/kapi-*/
/.claude/skills/bowrain-*/
/packages/kapi-claude-plugin/skills/

# Throwaway kapi config/data/cache home for in-repo (non-dogfood) invocations — see Makefile KAPI_ISO_ENV
.kapi-iso/

# Compiled Go tool binaries (built into their module dirs by `go build ./...`)
/scripts/gen-refs/gen-refs
/scripts/contract-audit/contract-audit
/scripts/checkeval/checkeval
# Stray build outputs (use `make` targets, which place binaries under bin/ or
# the wasm demo dir — these default `go build` outputs must never be committed)
/bowrain/bowrain
/kapi/kapi-wasm-cli
