{
  "realm": "bowrain",
  "enabled": true,
  "loginTheme": "bowrain",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "sslRequired": "none",
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@bowrain.cloud",
    "fromDisplayName": "Bowrain",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "clients": [
    {
      "clientId": "bowrain",
      "name": "Bowrain",
      "enabled": true,
      "publicClient": false,
      "secret": "bowrain-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:8080/api/v1/auth/callback",
        "http://localhost:8080/api/v1/auth/desktop/callback",
        "http://localhost:8080/*",
        "https://bowrain.mymac/api/v1/auth/callback",
        "https://bowrain.mymac/api/v1/auth/desktop/callback",
        "https://bowrain.mymac/*",
        "https://dev.bowrain.cloud/api/v1/auth/callback",
        "https://dev.bowrain.cloud/api/v1/auth/desktop/callback",
        "https://dev.bowrain.cloud/*",
        "https://bowrain.cloud/api/v1/auth/callback",
        "https://bowrain.cloud/api/v1/auth/desktop/callback",
        "https://bowrain.cloud/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "https://bowrain.mymac",
        "https://dev.bowrain.cloud",
        "https://bowrain.cloud"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true",
        "oauth2.device.polling.interval": "5",
        "backchannel.logout.url": "http://host.docker.internal:8080/api/v1/auth/backchannel-logout",
        "backchannel.logout.session.required": "false",
        "backchannel.logout.revoke.offline.tokens": "true"
      }
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "placeholder-google-client-id",
        "clientSecret": "placeholder-google-client-secret",
        "defaultScope": "openid email profile"
      }
    },
    {
      "alias": "github",
      "providerId": "github",
      "enabled": true,
      "trustEmail": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "placeholder-github-client-id",
        "clientSecret": "placeholder-github-client-secret",
        "defaultScope": "user:email"
      }
    }
  ],
  "users": [
    {
      "username": "admin@example.com",
      "email": "admin@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}
