{
  "realm": "bowrain",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "verifyEmail": true,
  "loginWithEmailAllowed": true,
  "sslRequired": "none",
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@bowrain.cloud",
    "fromDisplayName": "Bowrain",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "clients": [
    {
      "clientId": "bowrain",
      "name": "Bowrain",
      "enabled": true,
      "publicClient": false,
      "secret": "bowrain-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:8080/api/v1/auth/callback",
        "http://localhost:8080/api/v1/auth/desktop/callback",
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true",
        "oauth2.device.polling.interval": "5"
      }
    }
  ],
  "users": [
    {
      "username": "admin@example.com",
      "email": "admin@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ]
}
