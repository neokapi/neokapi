{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@neokapi/ui-primitives": ["../../../../packages/ui/src"],
      "@neokapi/ui-primitives/*": ["../../../../packages/ui/src/*"],
      "@neokapi/flow-editor": ["../../../../packages/flow-editor/src"],
      "@neokapi/flow-editor/*": ["../../../../packages/flow-editor/src/*"]
    }
  },
  "include": ["src"]
}
