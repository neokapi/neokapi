# Version control
.git/
.github/

# Build artifacts
bin/
coverage/

# IDE
.idea/
.vscode/
*.swp

# Node modules (installed in container). Match at EVERY level — pnpm creates
# per-package node_modules with symlinked binaries (e.g. packages/kapi-format/
# node_modules/esbuild) that break Docker's COPY ("cannot copy to non-directory").
node_modules/
**/node_modules/
**/node_modules

# Frontend dist (built in container)
bowrain/apps/web/dist/
bowrain/apps/bowrain/frontend/dist/

# Bowrain desktop app (not needed for server)
bowrain/apps/bowrain/
# Allow package.json for npm workspace resolution in Docker builds
!bowrain/apps/bowrain/frontend/package.json

# Website / docs
web/

# OS files
.DS_Store
Thumbs.db

# Plugin binaries
neokapi-plugin-*

# Test / CI artifacts
test-results/
playwright-report/

# Serena / Claude
.serena/
.claude/
