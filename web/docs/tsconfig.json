{
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    // "@site/*" maps to the project root. Paths resolve relative to this
    // tsconfig — no baseUrl, since tsgolint (which powers `vp check` type
    // checking) does not support compilerOptions.baseUrl.
    "paths": {
      "@site/*": ["./*"]
    },
    "resolveJsonModule": true,
    // The reference pages import workspace packages (@neokapi/ui-primitives,
    // flow-editor) whose source uses explicit `.ts` import specifiers. Allow
    // them so typecheck can follow the import graph.
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["build", ".docusaurus", "node_modules"]
}
