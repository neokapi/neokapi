{
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    // baseUrl must be set here (not only in the extended config) so the
    // inherited "@site/*" path mapping resolves against the project root
    // rather than the base config's node_modules directory.
    "baseUrl": ".",
    "paths": {
      "@site/*": ["./*"]
    },
    "resolveJsonModule": true,
    // The reference pages import workspace packages (@neokapi/ui-primitives,
    // flow-editor) whose source uses explicit `.ts` import specifiers. Allow
    // them so typecheck can follow the import graph.
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["build", ".docusaurus", "node_modules"]
}
