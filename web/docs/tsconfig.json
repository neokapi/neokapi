{
  // Inlined from @docusaurus/tsconfig MINUS compilerOptions.baseUrl. tsgolint
  // (which powers `vp check`) rejects baseUrl, and a baseUrl inherited via
  // `extends` cannot be removed by a child config — so we inline the Docusaurus
  // recommended options here instead of extending. "@site/*" resolves through
  // `paths` relative to this tsconfig's directory (no baseUrl needed in TS 5.x).
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@site/*": ["./*"]
    },
    "resolveJsonModule": true,
    // The reference pages import workspace packages (@neokapi/ui-primitives,
    // flow-editor) whose source uses explicit `.ts` import specifiers. Allow
    // them so typecheck can follow the import graph.
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["build", ".docusaurus", "node_modules"]
}
