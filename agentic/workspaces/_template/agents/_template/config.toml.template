[llm]
# ZeroClaw native env vars handle provider config

[security]
# Adjust allowed commands based on agent role:
# - L10N Engineer: ["git", "gh", "bowrain", "ls", "cat", "diff"]
# - Language Expert: []
# - Reviewer: []
allowed_commands = [{{ALLOWED_COMMANDS}}]

[mcp]
[[mcp.servers]]
name = "bowrain"
transport = "http"
url = "${BRAVO_MCP_ENDPOINT}"
headers = { Authorization = "Bearer ${BRAVO_AGENT_TOKEN}" }
tool_timeout_secs = 120

[daemon]
# Choose one scheduling strategy:
#
# Option A: Cron-based (for scheduled tasks)
# [daemon.cron]
# "task-name" = "0 9 * * 1-5"   # Weekdays at 9am
#
# Option B: Heartbeat-driven (for reactive tasks)
# heartbeat_interval_secs = 7200   # Every 2 hours
