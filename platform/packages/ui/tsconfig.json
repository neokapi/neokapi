{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "typeRoots": [
      "../../node_modules/@types",
      "../../../packages/ui/node_modules/@types",
      "../../../node_modules/@types"
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@neokapi/ui-primitives": ["../../../packages/ui/src"],
      "@neokapi/ui-primitives/*": ["../../../packages/ui/src/*"]
    }
  },
  "include": ["src", "src/**/*.json"],
  "exclude": ["src/__tests__"]
}
