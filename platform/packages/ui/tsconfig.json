{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@neokapi/ui-primitives": ["../../../packages/ui/src"],
      "@neokapi/ui-primitives/*": ["../../../packages/ui/src/*"]
    }
  },
  "include": ["src", "src/**/*.json", "../../../packages/ui/src"],
  "exclude": ["src/__tests__", "../../../packages/ui/src/stories"]
}
