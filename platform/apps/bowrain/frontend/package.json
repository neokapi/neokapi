{
  "name": "bowrain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "tsc && vp build",
    "build:dev": "vp build",
    "preview": "vp preview",
    "check": "vp check",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "screenshots": "npx playwright test e2e/screenshots.spec.ts",
    "recordings": "npx playwright test --config=playwright.recordings.config.ts",
    "recordings:headed": "npx playwright test --config=playwright.recordings.config.ts --headed",
    "recordings:copy": "THEME=dark ./scripts/copy-recordings.sh && THEME=light ./scripts/copy-recordings.sh",
    "recordings:all": "npm run recordings && npm run recordings:copy"
  },
  "dependencies": {
    "@lexical/react": "^0.41.0",
    "@tailwindcss/vite": "^4.2.1",
    "@wailsio/runtime": "^3.0.0-alpha.79",
    "@xyflow/react": "^12.10.1",
    "lexical": "^0.41.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "^5.8.0",
    "vite-plus": "^0.1.11"
  }
}
