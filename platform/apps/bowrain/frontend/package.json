{
  "name": "bowrain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:dev": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "screenshots": "npx playwright test e2e/screenshots.spec.ts",
    "recordings": "npx playwright test --config=playwright.recordings.config.ts",
    "recordings:headed": "npx playwright test --config=playwright.recordings.config.ts --headed",
    "recordings:copy": "THEME=dark ./scripts/copy-recordings.sh && THEME=light ./scripts/copy-recordings.sh",
    "recordings:all": "npm run recordings && npm run recordings:copy"
  },
  "dependencies": {
    "@lexical/react": "^0.39.0",
    "@tailwindcss/vite": "^4.1.18",
    "@wailsio/runtime": "^3.0.0-alpha.73",
    "@xyflow/react": "^12.10.0",
    "lexical": "^0.39.0",
    "lucide-react": "^0.563.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
