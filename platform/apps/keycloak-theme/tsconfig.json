{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@neokapi/ui": ["../../packages/ui/src"],
      "@neokapi/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.stories.tsx"],
  "references": [{ "path": "../../packages/ui" }]
}
