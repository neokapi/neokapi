# ZeroClaw configuration for @bravo agent containers.
# Rendered from template at container startup via envsubst.

# LLM provider configuration.
# Rendered from BRAVO_MODEL_* env vars at container startup.
[llm]
provider = "${BRAVO_MODEL_PROVIDER}"
model = "${BRAVO_MODEL_NAME}"
api_base = "${BRAVO_MODEL_API_BASE}"
api_key = "${BRAVO_MODEL_API_KEY}"

[gateway]
port = 42617
host = "0.0.0.0"
allow_public_bind = true
require_pairing = false

[mcp]
enabled = true
deferred_loading = false

[[mcp.servers]]
name = "bowrain"
transport = "http"
url = "${BRAVO_MCP_ENDPOINT}"
headers = { Authorization = "Bearer ${BRAVO_AGENT_TOKEN}" }
tool_timeout_secs = 120
